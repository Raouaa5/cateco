{% import '@SyliusShop/shared/macro/loader.html.twig' as loader %}
{% import "@SyliusShop/shared/macro/money.html.twig" as money %}

<style>
.c-summary-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 0.5px solid #F0EDE8;
    padding-bottom: 14px;
    margin-bottom: 14px;
}
.c-summary-title {
    font-size: 14px;
    font-weight: 800;
    color: #1A1A1A;
}
.c-summary-count {
    background: #F5F4F0;
    color: #888;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 4px;
}
.c-summary-row {
    display: flex;
    justify-content: space-between;
    border-bottom: 0.5px solid #F0EDE8;
    padding-bottom: 10px;
    margin-bottom: 10px;
}
.c-summary-label {
    font-size: 12px;
    color: #888;
}
.c-summary-val {
    font-size: 12px;
    font-weight: 700;
    color: #1A1A1A;
}
.c-summary-free {
    color: #2e7d32;
    font-weight: 700;
    font-size: 12px;
}
.c-summary-total-wrap {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
}
.c-summary-total-lbl {
    font-size: 14px;
    font-weight: 800;
    color: #1A1A1A;
}
.c-summary-total-val {
    font-size: 22px;
    font-weight: 800;
    color: #E87722;
}
.c-club-strip {
    background: #FFF0E0;
    border: 0.5px solid #F5C89A;
    border-radius: 8px;
    padding: 10px 12px;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
}
.c-club-icon {
    width: 24px;
    height: 24px;
    background: #E87722;
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}
.c-club-text {
    font-size: 10px;
    color: #B85A00;
    font-weight: 600;
    line-height: 1.4;
}
</style>

<div>
    {% set cart = cart is defined and cart is not null ? cart : (resource is defined ? resource : null) %}
    {{ loader.render() }}
    
    <div class="c-summary-header">
        <div class="c-summary-title">Résumé de la commande</div>
        <div class="c-summary-count">{{ cart.items|length }} {% if cart.items|length > 1 %}articles{% else %}article{% endif %}</div>
    </div>
    
    <div class="c-summary-row">
        <div class="c-summary-label">Sous-total</div>
        <div class="c-summary-val">{{ money.convertAndFormat(cart.itemsTotal) }}</div>
    </div>
    
    <div class="c-summary-row">
        <div class="c-summary-label">Frais de livraison</div>
        {% if cart.shippingTotal > 0 %}
            <div class="c-summary-val">{{ money.convertAndFormat(cart.shippingTotal) }}</div>
        {% else %}
            <div class="c-summary-free">Gratuit</div>
        {% endif %}
    </div>
    
    <div class="c-summary-row" style="border-bottom: none; margin-bottom: 16px;">
        <div class="c-summary-label">Taxes</div>
        <div class="c-summary-val">{{ money.convertAndFormat(cart.taxTotal) }}</div>
    </div>
    
    <div class="c-summary-total-wrap">
        <div class="c-summary-total-lbl">Total</div>
        <div class="c-summary-total-val" id="sylius-cart-grand-total" {{ sylius_test_html_attribute('cart-grand-total') }}>{{ money.convertAndFormat(cart.total) }}</div>
    </div>
    
    <div class="c-club-strip">
        <div class="c-club-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
              <path fill="#fff" d="m8 2.748-.717-.737C5.6.281 2.514.878 1.4 3.053c-.523 1.023-.641 2.5.314 4.385.92 1.815 2.834 3.989 6.286 6.357 3.452-2.368 5.365-4.542 6.286-6.357.955-1.886.838-3.362.314-4.385C13.486.878 10.4.28 8.717 2.01L8 2.748zM8 15C-7.333 4.868 3.279-3.04 7.824 1.143c.06.055.119.112.176.171a3.12 3.12 0 0 1 .176-.17C12.72-3.042 23.333 4.867 8 15z"/>
            </svg>
        </div>
        <div class="c-club-text">Rejoignez le Club Catéco et économisez -10% sur toute la commande</div>
    </div>
</div>
