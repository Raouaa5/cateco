{% set prefixes = hookable_metadata.prefixes|default([])|merge(['sylius_shop.shared.form']) %}

<div class="mb-4 cateco-checkout-shipping-section {% if not hookable_metadata.context.is_diffrent_address %}d-none {% endif %}">
    <div class="h4 mb-4">{{ 'sylius.ui.shipping_address'|trans }}</div>

    {# ── Address book component (radio cards + add link) ─────── #}
    {{ component('sylius_shop:checkout:address:address_book', {field: 'shippingAddress'}) }}

    {# ── New address form. Left visible by default as requested. ──── #}
    <div id="cateco-new-addr-form-shippingAddress" class="cateco-new-addr-form">
        {% hook 'address' with { _prefixes: prefixes, 'form': hookable_metadata.context.form.shippingAddress, 'type': 'shipping' } %}
    </div>
</div>
