{% set order = hookable_metadata.context.order %}
{% set enabled = order.payments|length %}

{% for payment in hookable_metadata.context.form.payments %}
    {% set enabled = enabled and payment.method|length %}
{% endfor %}

<div class="d-flex justify-content-between align-items-center flex-column flex-sm-row gap-3 mt-4">
    {# Back button — small outlined #}
    {% if sylius_is_shipping_required(order) %}
        <a href="{{ path('sylius_shop_checkout_select_shipping') }}"
           class="btn btn-outline-secondary btn-icon"
           style="font-size:0.88rem; padding: 10px 18px; border-radius: 8px;">
            &lsaquo; Modifier le mode de livraison
        </a>
    {% else %}
        <a href="{{ path('sylius_shop_checkout_address') }}"
           class="btn btn-outline-secondary btn-icon"
           style="font-size:0.88rem; padding: 10px 18px; border-radius: 8px;">
            &lsaquo; Modifier l'adresse
        </a>
    {% endif %}

    {# Suivant — wide orange button #}
    <button type="submit"
            class="btn {% if not enabled %}disabled{% endif %}"
            {% if not enabled %}disabled{% endif %}
            style="background: #E87722; color: #fff; font-weight: 700; font-size: 1rem; padding: 12px 48px; border-radius: 8px; border: none; flex: 1; max-width: 400px; transition: background 0.2s;"
            onmouseover="this.style.background='#d86b1c'"
            onmouseout="this.style.background='#E87722'"
            {{ sylius_test_html_attribute('next-step') }}>
        Suivant &rsaquo;
    </button>
</div>
