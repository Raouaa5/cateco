{% extends '@SyliusShop/checkout/common/layout.html.twig' %}

{% set prefixes = ['sylius_shop.checkout'] %}
{% set active_step = 'complete' %}

{% block title %}
    {{ 'sylius.ui.complete'|trans }} | {{ parent() }}
{% endblock %}

{% block content %}
    <style>
        /* Expand the checkout container width to allow both cards to be wider */
        @media (min-width: 1200px) {
            .container { max-width: 1320px !important; }
        }
        .c-summary-main-title {
            font-size: 24px;
            font-weight: 800;
            color: #1A1A1A;
            margin-bottom: 24px;
        }
        .c-summary-main-title span {
            color: #E87722;
        }
    </style>

    {# Custom full-width steps header #}
    {{ include('@SyliusShop/checkout/common/checkout_header_steps.html.twig', {active: 4}) }}

    <div class="c-summary-main-title">
        Récapitulatif de votre <span>commande</span>
    </div>

    {# Custom 2-column grid inside the flexed content block #}
    <div class="row">
        <div class="col-12 col-lg-8 pe-lg-2">
            {% hook 'complete' with { _prefixes: prefixes, active_step, form, order } %}
        </div>
        <div class="col-12 col-lg-4 ps-lg-2 mt-4 mt-lg-0">
            {{ include('@SyliusShop/checkout/complete/sidebar.html.twig') }}
        </div>
    </div>
{% endblock %}

{# Remove default sidebar to allow content col to expand to 100% #}
{% block sidebar %}{% endblock %}
