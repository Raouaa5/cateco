{% set form = hookable_metadata.context.form %}

<style>
.cateco-payment-card {
    background: #ffffff;
    border: 1px solid #e8e4de;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}
.cateco-payment-card-title {
    display: flex; align-items: center; gap: 10px;
    font-size: 1.05rem; font-weight: 700; color: #2c2c2c;
    margin-bottom: 1.25rem; padding-bottom: 1rem;
    border-bottom: 1px solid #f0ede8;
}
.cateco-payment-card-title svg { color: #E87722; }
.cateco-secure-badge {
    background: #f0faf0; border: 1px solid #b8e6b8; border-radius: 8px;
    padding: 10px 14px; display: flex; align-items: center; gap: 8px;
    font-size: 0.82rem; color: #2e7d32; font-weight: 600; margin-top: 1.25rem;
}
</style>

<div class="cateco-payment-card">
    <div class="cateco-payment-card-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
            <line x1="1" y1="10" x2="23" y2="10"></line>
        </svg>
        Paiement #1
    </div>

    {{ form_errors(form.method) }}

    {# Restore original hook chain so Mollie sub-methods (iDEAL/Wero) still render #}
    {% for key, choice_form in form.method %}
        {% set method = form.method.vars.choices[key].data %}
        {% set factory_name = method.gatewayConfig.factoryName %}
        {% hook ['choice.' ~ factory_name, 'choice'] with { 'parent_form': form, 'form': choice_form, 'method': method } %}
    {% else %}
        {% hook 'choice#unavailable' %}
    {% endfor %}

    <div class="cateco-secure-badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        Paiement 100% sécurisé — données protégées par SSL 256-bit
    </div>
</div>
