<!DOCTYPE html>

<html lang="{{ app.request.locale|slice(0, 2) }}">
        <head>
                <meta charset="utf-8">
                <meta http-equiv="X-UA-Compatible" content="IE=edge">
                <meta content="width=device-width, initial-scale=1, maximum-scale=5" name="viewport">

                <title>
                        {% block title %}
                                {{ sylius.channel.name }}
                        {% endblock %}
                </title>

                <link rel="preconnect" href="https://fonts.googleapis.com">
                <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
                <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;700;800&display=swap" rel="stylesheet">

                <style>
                        :root {
                                --color-primary: #E87722;
                                --color-primary-hover: #C85A00;
                                --color-primary-tint: #FFF0E8;
                                --color-text-heading: #1A1A1A;
                                --color-text-body: #555555;
                                --color-text-muted: #888888;
                                --color-text-inverse: #FFFFFF;
                                --color-bg-page: #F3F4F6;
                                --color-bg-card: #FFFFFF;
                                --color-bg-sand: #F5F0E6;
                                --color-border: #E0DCD5;
                                --color-success-bg: #E8F4E8;
                                --color-success-text: #2A8B2A;
                                --color-error-bg: #FDECEA;
                                --color-error-text: #D02020;
                                --radius-sm: 6px;
                                --radius-md: 10px;
                                --radius-lg: 14px;
                                --radius-xl: 20px;
                                --shadow-card: 0 1px 4px rgba(0,0,0,0.06);
                                --shadow-hover: 0 4px 16px rgba(0,0,0,0.12);
                                --font-base: 'DM Sans', sans-serif;
                        }

                        /* Forcibly hide any top containers or newsletters from base themes */
                        #sylius-top-bar, .container.py-4, nav.bg-primary { display: none !important; }
                        
                        /* Snap everything to the top */
                        html, body { 
                                margin: 0 !important; 
                                padding: 0 !important; 
                                scroll-padding-top: 144px; /* Space for both navbars */
                                font-family: var(--font-base) !important;
                                font-weight: 400;
                                color: var(--color-text-body) !important;
                                background-color: var(--color-bg-page) !important;
                        }

                        h1, h2, h3, h4, h5, h6 {
                                font-weight: 800 !important;
                                color: var(--color-text-heading) !important;
                        }

                        /* Emergency Utility Fallbacks */
                        .sr-only { position: absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); border-width:0; }
                        .container { max-width: 1280px; margin-left: auto; margin-right: auto; padding-left: 1.5rem; padding-right: 1.5rem; }
                        .flex { display: flex; }
                        .flex-col { flex-direction: column; }
                        .min-h-screen { min-height: 100vh; }
                        .bg-gray-50 { background-color: #F9FAFB; }
                        .mx-auto { margin-left: auto; margin-right: auto; }
                        .px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
                        .lg\:px-12 { padding-left: 3rem; padding-right: 3rem; }
                        
                        /* Cateco Brand Styles */
                        .main-header, .header-main {
                          background: var(--color-bg-card) !important;
                          border-bottom: 1px solid var(--color-border);
                        }
                        .site-name a {
                          color: var(--color-text-heading) !important;
                          font-weight: 900;
                          font-size: 1.75rem;
                          text-decoration: none;
                        }
                        .site-name a span {
                          color: var(--color-primary) !important;
                        }
                        .btn-primary {
                          background: var(--color-primary) !important;
                          color: var(--color-text-inverse) !important;
                          border: none;
                          padding: 0.5rem 1.75rem;
                          border-radius: var(--radius-sm);
                          font-weight: 700;
                          transition: background 0.2s, transform 0.2s;
                        }
                        .btn-primary:hover {
                          background: var(--color-primary-hover) !important;
                          transform: translateY(-1px);
                        }
                        
                        /* Simple Category Menu Fallback */
                        .category-menu-container {
                            background: white;
                            border-bottom: 1px solid #e5e7eb;
                            position: sticky;
                            top: 0;
                            z-index: 40;
                        }

                        /* --- PRODUCT CARD STYLES --- */
                        .cateco-product-card {
                            background: var(--color-bg-card) !important;
                            border-radius: var(--radius-md) !important;
                            overflow: hidden !important;
                            box-shadow: var(--shadow-card) !important;
                            transition: transform 0.25s ease, box-shadow 0.25s ease !important;
                            display: flex !important;
                            flex-direction: column !important;
                            border: 1px solid var(--color-border) !important;
                        }
                        .cateco-product-card:hover { transform: translateY(-4px) !important; box-shadow: var(--shadow-hover) !important; }

                        /* Image: square, dominant */
                        .product-image-wrapper { position: relative; width: 100%; aspect-ratio: 1/1; background: #f5f5f5 !important; display: flex; align-items: center; justify-content: center; overflow: hidden; }
                        .product-image-wrapper img { width: 100% !important; height: 100% !important; object-fit: cover !important; padding: 0 !important; transition: transform 0.4s ease !important; }
                        .cateco-product-card:hover .product-image-wrapper img { transform: scale(1.06) !important; }

                        /* Heart button — smaller */
                        .wishlist-heart-btn { position: absolute; top: 0.6rem; right: 0.6rem; width: 36px; height: 36px; border-radius: 50%; background: #f97316 !important; color: white !important; border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 3px 8px rgba(249, 115, 22, 0.4); z-index: 5; transition: transform 0.2s !important; }
                        .wishlist-heart-btn:hover { transform: scale(1.1) !important; background: #ea580c !important; }
                        .wishlist-heart-btn svg { width: 18px; height: 18px; }

                        /* Compact text strip */
                        .product-content { padding: 0.85rem 1rem !important; display: flex; flex-direction: column; gap: 0.3rem; }

                        /* Title — small, normal weight */
                        .product-title { font-size: 0.85rem !important; font-weight: 600 !important; color: #111827 !important; margin: 0 !important; line-height: 1.35 !important; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
                        .product-title a { color: inherit !important; text-decoration: none !important; }
                        .product-title a:hover { color: #f97316 !important; }

                        /* Short description — hidden to save space */
                        .product-extract { display: none !important; }

                        /* Price section — compact */
                        .price-labels { display: flex; flex-direction: column; gap: 0.1rem; margin: 0 !important; }
                        .original-price { font-size: 0.7rem !important; color: #d1d5db !important; text-decoration: line-through !important; font-weight: 400; line-height: 1; }
                        .club-price-info { display: flex; align-items: center; gap: 0.5rem; }
                        .final-price { font-size: 1.1rem !important; font-weight: 800 !important; color: #111827 !important; letter-spacing: -0.02em; line-height: 1; }
                        .club-badge { display: flex; flex-direction: column; align-items: center; background: linear-gradient(145deg, #f97316 0%, #ea580c 100%); color: white !important; padding: 0.15rem 0.45rem; border-radius: 0.35rem; line-height: 1.1 !important; font-weight: 800; text-transform: uppercase; flex-shrink: 0; }
                        .club-text { font-size: 0.4rem !important; opacity: 0.85; }
                        .club-brand { font-size: 0.65rem !important; }

                        /* Add to cart link — very compact */
                        .btn-add-to-cart-link { display: inline-flex; align-items: center; gap: 0.35rem; background: transparent; border: none; color: #6b7280 !important; font-weight: 600 !important; font-size: 0.75rem !important; padding: 0.4rem 0 0 0; cursor: pointer; text-decoration: none !important; border-top: 1px solid #f3f4f6; margin-top: 0.35rem; width: 100%; transition: color 0.2s; }
                        .btn-add-to-cart-link:hover { color: #f97316 !important; }
                        .btn-add-to-cart-link svg { width: 14px; height: 14px; flex-shrink: 0; }

                        /* Modal Styles */
                        #wishlist-login-modal { display: none; position: fixed; inset: 0; z-index: 10000; background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(8px); align-items: center; justify-content: center; padding: 1.5rem; }
                        #wishlist-login-modal.active { display: flex; }
                        .modal-container { background: white; width: 100%; max-width: 550px; border-radius: 1.25rem; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); overflow: hidden; animation: modal-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); }
                        @keyframes modal-pop { 0% { transform: scale(0.9); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
                        .modal-header { padding: 1.5rem 2rem; border-bottom: 1px solid #f3f4f6; display: flex; align-items: center; justify-content: space-between; }
                        .modal-header h2 { font-size: 1.5rem !important; font-weight: 800 !important; color: #111827 !important; margin: 0; }
                        .close-modal-btn { background: transparent; border: none; color: #9ca3af; cursor: pointer; padding: 0.5rem; border-radius: 50%; }
                        .modal-body { padding: 2rem; }
                        .modal-body p { color: #4b5563; font-size: 1.15rem; line-height: 1.6; margin: 0; }
                        .modal-footer { padding: 1.5rem 2rem; border-top: 1px solid #f3f4f6; display: flex; justify-content: flex-end; gap: 1.25rem; background: #f9fafb; }
                        .btn-modal-close { padding: 0.85rem 1.75rem; background: #e5e7eb; color: #374151; border-radius: 0.75rem; font-weight: 700; border: none; cursor: pointer; font-size: 1rem; }
                        .btn-modal-login { padding: 0.85rem 1.75rem; background: #f97316; color: white !important; border-radius: 0.75rem; font-weight: 700; border: none; text-decoration: none; font-size: 1rem; box-shadow: 0 4px 12px rgba(249, 115, 22, 0.3); }

                        /* Grid — 3 cards per row */
                        .products-grid {
                            display: grid !important;
                            grid-template-columns: repeat(1, 1fr) !important;
                            gap: 2rem !important;
                            padding: 2rem 0 !important;
                        }
                        @media (min-width: 640px)  { .products-grid { grid-template-columns: repeat(2, 1fr) !important; } }
                        @media (min-width: 1024px) { .products-grid { grid-template-columns: repeat(3, 1fr) !important; } }
                        @media (min-width: 1280px) { .products-grid { grid-template-columns: repeat(3, 1fr) !important; } }
                        
                        /* Push down checkout steps */
                        body[data-route^="sylius_shop_checkout"] #main {
                            padding-top: 2.5rem !important;
                        }
                </style>

        {% block metatags %}
            <meta name="description" content="Cateco - Équipements pour la maison">
            <meta name="keywords" content="Cateco, Équipements, Maison">
        {% endblock %}

                {% block stylesheets %}
                        {% hook 'sylius.shop.layout.stylesheets' %}
                        {{ encore_entry_link_tags('shop-entry', null, 'shop') }}
                        {{ encore_entry_link_tags('app-shop-entry', null, 'app.shop') }}
                {% endblock %}

                {% hook 'sylius.shop.layout.head' %}
        </head>

        <body class="flex flex-col min-h-screen bg-gray-50" data-route="{{ app.request.get('_route') }}">
                <a class="sr-only focus:not-sr-only focus-visible:not-sr-only !absolute !top-2 !left-2" href="#main">Skip to content</a>

                {% hook 'sylius.shop.layout.before_body' %}

                {% block header %}
                    <header style="position: sticky; top: 0; z-index: 10000; width: 100%; background: var(--color-bg-card); display: flex; flex-direction: column; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                        {% include '@SyliusShop/shared/layout/base/header/cateco_navbar.html.twig' %}
                        {# Optimized: Direct inclusion instead of sub-request for massive speed boost #}
                        {% include '@SyliusShop/shared/layout/base/header/navbar/menu.html.twig' with {'taxons': get_mega_menu_taxons()} %}
                    </header>
                {% endblock %}

                <div class="min-h-[50vh] flex-1 pb-16 w-full" id="main">
                        {% include '@SyliusShop/shared/layout/base/header/flashes.html.twig' %}

                        {% hook 'sylius.shop.layout.before_content' %}

                        {% block content %}{% endblock %}

                        {% hook 'sylius.shop.layout.after_content' %}
                </div>

                {% block footer %}
                        {% include '@SyliusShop/homepage/_trust_indicators.html.twig' %}
                        {% include '@SyliusShop/shared/layout/base/footer/content.html.twig' %}
                {% endblock %}

                {% block javascripts %}
                        {% hook 'sylius.shop.layout.javascripts' %}
                        {{ encore_entry_script_tags('shop-entry', null, 'shop') }}
                        {{ encore_entry_script_tags('app-shop-entry', null, 'app.shop') }}
                        <script>
                            document.addEventListener('error', function(e) {
                                if (e.target && e.target.tagName && e.target.tagName.toLowerCase() === 'img') {
                                    // Use a data attribute to prevent infinite loops if the placeholder is also broken
                                    if (!e.target.dataset.triedFallback) {
                                        e.target.dataset.triedFallback = 'true';
                                        e.target.src = '/assets/shop/images/no-image.png';
                                        e.target.classList.add('broken-image-fallback');
                                    }
                                }
                            }, true);
                        </script>
                {% endblock %}

                {% hook 'sylius.shop.layout.after_body' %}

                {# Wishlist Login Modal #}
                <div id="wishlist-login-modal">
                    <div class="modal-container">
                        <div class="modal-header">
                            <h2>S'identifier</h2>
                            <button type="button" class="close-modal-btn" onclick="hideLoginModal()">
                                <svg xmlns="http://www.w3.org/2000/svg" style="width:24px;height:24px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            </button>
                        </div>
                        <div class="modal-body">
                            <p>Vous devez être connecté pour enregistrer des produits dans votre liste de souhaits.</p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn-modal-close" onclick="hideLoginModal()">Fermer</button>
                            <a href="{{ path('sylius_shop_login') }}" class="btn-modal-login">S'identifier</a>
                        </div>
                    </div>
                </div>

                <script>
                    function showLoginModal() {
                        document.getElementById('wishlist-login-modal').classList.add('active');
                    }
                    function hideLoginModal() {
                        document.getElementById('wishlist-login-modal').classList.remove('active');
                    }
                </script>

                <script>
                    // Auto-fill registration email if redirected from the newsletter forms
                    document.addEventListener("DOMContentLoaded", function() {
                        const urlParams = new URLSearchParams(window.location.search);
                        const emailParam = urlParams.get('email');
                        if (emailParam && (window.location.pathname.includes('/register') || window.location.pathname.includes('/inscription'))) {
                            const emailInput = document.querySelector('input[type="email"][name$="[email]"]');
                            if (emailInput) {
                                emailInput.value = emailParam;
                            }
                        }
                    });
                </script>
        </body>
</html>
