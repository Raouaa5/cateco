<!-- Overlay (click to close) -->
<div id="cart-overlay" onclick="toggleCartSidebar()"></div>

<!-- Cart Drawer -->
<div id="cart-sidebar">
    <!-- Header -->
    <div class="cart-sidebar-header">
        <h2>Panier</h2>
        <button class="cart-close-btn" onclick="toggleCartSidebar()">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </div>

    {{ component('sylius_shop:cart:widget', {'template': '@SyliusShop/shared/layout/base/header/cart_sidebar_content.html.twig'}) }}
</div>

<script>
    function toggleCartSidebar() {
        const route = document.body.dataset.route || '';
        const isCheckout = route.startsWith('sylius_shop_checkout');

        if (isCheckout) {
            // On checkout pages: redirect to cart page instead of opening sidebar
            const cartUrl = document.getElementById('cart-toggle-btn').dataset.cartUrl;
            window.location.href = cartUrl;
            return;
        }

        const sidebar = document.getElementById('cart-sidebar');
        const overlay = document.getElementById('cart-overlay');
        sidebar.classList.toggle('open');
        overlay.classList.toggle('open');
        document.body.style.overflow = sidebar.classList.contains('open') ? 'hidden' : '';
    }

    function removeCartItem(itemId, btn) {
        // Animate the row out immediately for a snappy feel
        const row = btn.closest('.cart-item-row');
        if (row) {
            btn.disabled = true;
            btn.style.opacity = '0.4';
            row.style.transition = 'opacity 0.2s, transform 0.2s';
            row.style.opacity = '0';
            row.style.transform = 'translateX(20px)';
        }

        // Build a hidden form and submit to cart summary page with item removal
        // Since Sylius doesn't expose a direct REST endpoint, we use the item quantity = 0 trick
        // via the cart update route
        const locale = document.documentElement.lang || 'fr';

        // Create and submit a background form to remove the item via cart item update
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/' + locale + '/cart/';
        form.style.display = 'none';

        // Sylius cart remove uses sylius_shop_cart_summary with removeItem hidden field
        const methodField = document.createElement('input');
        methodField.type = 'hidden';
        methodField.name = '_method';
        methodField.value = 'PATCH';
        form.appendChild(methodField);

        const removeField = document.createElement('input');
        removeField.type = 'hidden';
        removeField.name = 'sylius_cart[items][' + itemId + '][quantity]';
        removeField.value = '0';
        form.appendChild(removeField);

        document.body.appendChild(form);

        setTimeout(() => {
            if (row) row.remove();

            const remaining = document.querySelectorAll('#cart-sidebar .cart-item-row');
            // Update badge
            const badge = document.querySelector('#cart-toggle-btn span');
            if (badge) {
                const current = parseInt(badge.textContent) || 0;
                badge.textContent = Math.max(0, current - 1);
            }

            if (remaining.length === 0) {
                window.location.reload();
                return;
            }

            // Reload the page silently to sync Sylius state
            fetch(window.location.href, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .catch(() => {});
        }, 220);

        // Submit the form in background to actually remove the item from Sylius
        fetch('/' + locale + '/cart/', {
            method: 'POST',
            body: (() => {
                const fd = new FormData();
                fd.append('_method', 'PATCH');
                fd.append('sylius_cart[items][' + itemId + '][quantity]', '0');
                return fd;
            })(),
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            redirect: 'follow'
        }).catch(() => {});
    }
</script>
