            </a>
        {% endif %}
    </div>
</div>

<script>
    /* ── Mobile nav drawer ─────────────────────────────────── */
    function openMobileNav() {
        document.getElementById('mobile-nav-drawer').classList.add('open');
        document.getElementById('mobile-nav-overlay').classList.add('open');
        document.body.style.overflow = 'hidden';
    }
    function closeMobileNav() {
        document.getElementById('mobile-nav-drawer').classList.remove('open');
        document.getElementById('mobile-nav-overlay').classList.remove('open');
        document.body.style.overflow = '';
    }

    /* ── Categories drawer ─────────────────────────────────── */
    function openCatDrawer() {
        document.getElementById('cat-drawer').classList.add('open');
        document.getElementById('cat-drawer-overlay').classList.add('open');
        document.body.style.overflow = 'hidden';
    }
    function closeCatDrawer() {
        document.getElementById('cat-drawer').classList.remove('open');
        document.getElementById('cat-drawer-overlay').classList.remove('open');
        document.body.style.overflow = '';
    }
    function toggleCatAccordion(id) {
        var item = document.getElementById(id);
        if (item) item.classList.toggle('open');
    }

    /* ── Cart sidebar ──────────────────────────────────────── */
    function toggleCartSidebar() {
        var route   = document.body.dataset.route || '';
        if (route.indexOf('sylius_shop_checkout') === 0) {
            var btn = document.getElementById('cart-toggle-btn');
            if (btn) window.location.href = btn.dataset.cartUrl;
            return;
        }
        var sidebar = document.getElementById('cart-sidebar');
        var overlay = document.getElementById('cart-overlay');
        if (!sidebar || !overlay) return;
        sidebar.classList.toggle('open');
        overlay.classList.toggle('open');
        document.body.style.overflow = sidebar.classList.contains('open') ? 'hidden' : '';
    }

    /* ── Wishlist modal ────────────────────────────────────── */
    function showLoginModal() {
        var m = document.getElementById('wishlist-login-modal');
        if (m) m.classList.add('active');
    }
    function hideLoginModal() {
        var m = document.getElementById('wishlist-login-modal');
        if (m) m.classList.remove('active');
    }

    /* ── Registration email pre-fill ──────────────────────── */
    document.addEventListener('DOMContentLoaded', function () {
        var params = new URLSearchParams(window.location.search);
        var email  = params.get('email');
        var path   = window.location.pathname;
        if (email && (path.indexOf('/register') !== -1 || path.indexOf('/inscription') !== -1)) {
            var input = document.querySelector('input[type="email"][name$="[email]"]');
            if (input) input.value = email;
        }
    });
</script>
