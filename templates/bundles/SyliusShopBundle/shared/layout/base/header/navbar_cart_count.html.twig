{# templates/bundles/SyliusShopBundle/shared/layout/base/header/navbar_cart_count.html.twig #}
{# Bound to WidgetComponent #}
<div {{ attributes }}>
    <div style="position: relative;">
        <svg style="width: 24px; height: 24px; color: currentcolor;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
        </svg>
        {% if cart and cart.totalQuantity > 0 %}
            <span style="position: absolute; top: -5px; right: -8px; background: #dc2626; color: white; border-radius: 50%; width: 16px; height: 16px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: bold;">
                {{ cart.totalQuantity }}
            </span>
        {% else %}
             <span style="position: absolute; top: -5px; right: -8px; background: #dc2626; color: white; border-radius: 50%; width: 16px; height: 16px; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: bold;">0</span>
        {% endif %}
    </div>
</div>
