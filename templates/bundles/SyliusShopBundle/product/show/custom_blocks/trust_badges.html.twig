<div class="cateco-trust-badges mt-4 mb-4" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
    {% set trusts = [
        {'icon': '<path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>', 'label': 'Livraison en Guyane'},
        {'icon': '<path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>', 'label': 'Retours 30 jours'},
        {'icon': '<path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>', 'label': 'Paiement sécurisé'},
        {'icon': '<path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>', 'label': 'Qualité garantie'}
    ] %}
    
    {% for trust in trusts %}
    <div class="d-flex align-items-center gap-2">
        <div class="cateco-trust-icon" style="background: #FFF0E0; color: #E87722; width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
            <svg width="20" height="20" viewBox="0 0 24 24">{{ trust.icon|raw }}</svg>
        </div>
        <span style="font-size: 0.85rem; font-weight: 700; color: #4a5568;">{{ trust.label }}</span>
    </div>
    {% endfor %}
</div>
