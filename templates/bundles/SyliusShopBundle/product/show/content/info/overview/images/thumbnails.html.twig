{% set product = hookable_metadata.context.product|default(product|default(null)) %}
{% if product.images|length > 0 %}
<div class="cateco-thumbnails-wrapper d-flex flex-wrap gap-3 mt-0" style="order: 2;">
    {% for image in product.images %}
        {% set path = image.path is not null ? image.path|imagine_filter('sylius_shop_product_small_thumbnail') : asset('assets/shop/img/200x200.png') %}
        <div class="cateco-thumbnail {% if loop.first %}active{% endif %}" style="width: 80px; height: 80px; border-radius: 10px; overflow: hidden; background: #EAE8E3; cursor: pointer; border: 2px solid {% if loop.first %}#E87722{% else %}transparent{% endif %}; display: flex; align-items: center; justify-content: center;">
            <img src="{{ path }}" alt="{{ product.name }}" style="max-width: 80%; max-height: 80%; object-fit: contain; mix-blend-mode: multiply;" />
        </div>
    {% endfor %}
</div>

<style>
.cateco-thumbnail:hover {
    border-color: #E87722 !important;
}
</style>
{% endif %}
