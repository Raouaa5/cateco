{% set product = hookable_metadata.context.product|default(product|default(null)) %}
{% set path = product.images.first ? product.images.first.path : null %}

<div class="cateco-main-image-wrapper mb-0" style="position: relative; background-color: #F5F4F0; border-radius: 14px; padding: 0.5rem; display: flex; align-items: center; justify-content: center; width: 100%; min-height: 450px; overflow: hidden; order: 1; margin-top: 4rem !important;">
    
    {# Stock Badge Top Left #}
    {% set is_out_of_stock = true %}
    {% if product.simple and product.variants.first is not empty %}
        {% set v_stock = product.variants.first.onHand - product.variants.first.onHold %}
        {% set is_out_of_stock = (v_stock <= 0) or (not sylius_inventory_is_available(product.variants.first)) %}
    {% elseif not product.simple %}
        {# For variant products, if even one is available, we don't show the badge on the main image initially #}
        {% for variant in product.enabledVariants %}
            {% set v_stock = variant.onHand - variant.onHold %}
            {% if v_stock > 0 and sylius_inventory_is_available(variant) %}
                {% set is_out_of_stock = false %}
            {% endif %}
        {% endfor %}
    {% endif %}

    {% if is_out_of_stock %}
        <div style="position: absolute; top: 20px; left: 20px; background-color: #FDECEA; color: #b02020; padding: 6px 16px; border-radius: 50px; font-weight: 800; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; z-index: 10; font-family: 'Inter', sans-serif; box-shadow: 0 4px 12px rgba(176,32,32,0.1);">
            Rupture de stock
        </div>
    {% endif %}

    {# Clickable Image - triggers Fullscreen Overlay #}
    {% set original_path = product.images.first ? product.images.first.path|imagine_filter('sylius_shop_product_original') : asset('assets/shop/img/200x200.png') %}

    <div id="mainImageContainer" class="cateco-image-zoom-container d-block text-center w-100 h-100" 
         style="position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; cursor: pointer;" 
         onclick="catecoOpenFullscreen(event)">
        {% if path is not empty %}
            <img src="{{ path|imagine_filter('sylius_shop_product_large_thumbnail') }}" alt="{{ product.name }}" style="max-width: 100%; max-height: 100%; object-fit: contain; mix-blend-mode: multiply; pointer-events: none;" />
        {% else %}
            <img src="{{ original_path }}" alt="{{ product.name }}" style="max-width: 100%; max-height: 100%; object-fit: contain; pointer-events: none;" />
        {% endif %}
    </div>
</div>

{# Custom Fullscreen Overlay with native Zoom capability #}
<div id="catecoFullscreenOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(26,26,26,0.98); z-index: 99999; flex-direction: column; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s ease;">
    {# Header bar with close button #}
    <div style="position: absolute; top: 0; right: 0; width: 100%; display: flex; justify-content: flex-end; padding: 1.5rem; z-index: 100000; pointer-events: none;">
        <button onclick="catecoCloseFullscreen(event)" style="background: rgba(255,255,255,0.1); border: none; color: white; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; pointer-events: auto; transition: background 0.2s;" onmouseover="this.style.background='rgba(232,119,34,0.9)'" onmouseout="this.style.background='rgba(255,255,255,0.1)'">
            <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
    </div>

    {# Zoomable Canvas #}
    <div id="catecoZoomCanvas" style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; cursor: zoom-in;" 
         onclick="catecoToggleOverlayZoom(event)" onmousemove="catecoPanOverlayZoom(event)" data-zoomed="false">
        <img id="catecoOverlayImg" src="{{ original_path }}" alt="{{ product.name }}" style="max-width: 90vw; max-height: 90vh; object-fit: contain; transition: transform 0.2s ease-out; pointer-events: none;" />
    </div>

    {# Instruction Toast #}
    <div style="position: absolute; bottom: 2rem; background: rgba(0,0,0,0.6); color: #fff; padding: 8px 20px; border-radius: 30px; font-size: 0.85rem; pointer-events: none;">
        Cliquez pour zoomer
    </div>
</div>

<script>
function catecoOpenFullscreen(e) {
    if(e) { e.preventDefault(); e.stopPropagation(); }
    const overlay = document.getElementById('catecoFullscreenOverlay');
    overlay.style.display = 'flex';
    // Double requestAnimationFrame ensures the display:flex is rendered before opacity transitions
    requestAnimationFrame(() => requestAnimationFrame(() => {
        overlay.style.opacity = '1';
    }));
    document.body.style.overflow = 'hidden'; // Prevent page scrolling
}

function catecoCloseFullscreen(e) {
    if(e) { e.preventDefault(); e.stopPropagation(); }
    const overlay = document.getElementById('catecoFullscreenOverlay');
    overlay.style.opacity = '0';
    setTimeout(() => {
        overlay.style.display = 'none';
        document.body.style.overflow = '';
        
        // Reset zoom state on close
        const canvas = document.getElementById('catecoZoomCanvas');
        const img = document.getElementById('catecoOverlayImg');
        canvas.dataset.zoomed = 'false';
        canvas.style.cursor = 'zoom-in';
        img.style.transform = 'scale(1)';
    }, 300);
}

function catecoToggleOverlayZoom(e) {
    const canvas = e.currentTarget;
    const img = document.getElementById('catecoOverlayImg');
    
    if (canvas.dataset.zoomed === 'true') {
        canvas.dataset.zoomed = 'false';
        canvas.style.cursor = 'zoom-in';
        img.style.transform = 'scale(1)';
        img.style.transformOrigin = 'center center';
    } else {
        canvas.dataset.zoomed = 'true';
        canvas.style.cursor = 'zoom-out';
        
        // Calculate initial zoom relative to mouse click
        catecoPanOverlayZoom(e);
    }
}

function catecoPanOverlayZoom(e) {
    const canvas = e.currentTarget;
    if (canvas.dataset.zoomed !== 'true') return;
    
    const img = document.getElementById('catecoOverlayImg');
    const bounds = canvas.getBoundingClientRect();
    
    const x = e.clientX - bounds.left;
    const y = e.clientY - bounds.top;
    
    const xPercent = (x / bounds.width) * 100;
    const yPercent = (y / bounds.height) * 100;
    
    img.style.transformOrigin = `${xPercent}% ${yPercent}%`;
    img.style.transform = "scale(2.5)";
}
</script>
