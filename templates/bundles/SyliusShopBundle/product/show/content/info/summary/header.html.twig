{# Custom Header for Product Summary #}
{% set product = hookable_metadata.context.product|default(product|default(null)) %}
<div class="cateco-product-header mb-2">
    {# Main Category Label #}
    {% if product.mainTaxon is not null %}
        <div class="cateco-taxon-label mb-2 d-flex align-items-center gap-2" style="color: #E87722; font-size: 0.85rem; font-weight: 700; text-transform: uppercase;">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path></svg>
            {{ product.mainTaxon.name }}
        </div>
    {% endif %}

    <h1 class="cateco-product-title" style="font-size: 26px; font-weight: 800; color: #1A1A1A; margin: 0; line-height: 1.2;">
        {{ product.name }}
    </h1>
</div>
