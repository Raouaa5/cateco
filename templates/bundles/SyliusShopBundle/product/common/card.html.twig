{#
    Redesigned Product Card for Cateco
#}

{% set cheapest_variant = product|sylius_resolve_variant %}
{% if cheapest_variant is null and product.variants is not empty %}
    {% set cheapest_variant = product.variants.first %}
{% endif %}

{% set price = 0 %}
{% set original_price = 0 %}
{% set has_discount = false %}

{% if cheapest_variant is not null %}
    {% set price = cheapest_variant|sylius_calculate_price({'channel': sylius.channel}) %}
    {% set original_price = cheapest_variant|sylius_calculate_original_price({'channel': sylius.channel}) %}
    {% set has_discount = original_price > price %}
{% endif %}

<div class="cateco-product-card d-flex flex-column h-100" style="background: #ffffff; border-radius: 12px; overflow: hidden; border: 1px solid #E0DDD5; transition: transform 0.2s, box-shadow 0.2s;" {{ sylius_test_html_attribute('product', product.code) }}>
    
    {# Image Area #}
    <div style="background: #F5F0E8; position: relative; height: 240px; display: flex; align-items: center; justify-content: center; overflow: hidden; padding: 0.5rem;">
        
        {% set _in_wl = app.user ? is_in_wishlist(product.id) : false %}
        <button type="button"
                class="wishlist-heart-btn {% if _in_wl %}wl-active{% endif %}"
                data-product-id="{{ product.id }}"
                data-toggle-url="{{ path('app_wishlist_toggle', {productId: product.id, _locale: sylius.localeCode}) }}"
                data-login-url="{{ path('sylius_shop_login') }}"
                style="position: absolute; top: 12px; right: 12px; background: #fff; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border: none; color: #E87722; cursor: pointer; z-index: 2;">
            <svg width="16" height="16" fill="{{ _in_wl ? '#E87722' : 'none' }}" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
        </button>

        <a href="{{ path('sylius_shop_product_show', {'slug': product.slug, '_locale': sylius.localeCode}) }}" style="display:block;width:100%;height:100%; text-align: center;">
            {% if product.images is not empty %}
                {% set img = product.images.first %}
                {% set img_src = img.path[0:4] == 'http' ? img.path : img.path|imagine_filter('sylius_shop_product_original') %}
                <img src="{{ img_src }}"
                     alt="{{ product.name }}"
                     style="width: 100%; height: 100%; object-fit: contain; mix-blend-mode: multiply;"
                     onerror="this.style.display='none';this.parentNode.parentNode.querySelector('.no-img-placeholder').style.display='flex';">
            {% else %}
                <div class="no-img-placeholder" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#d1d5db;">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width:48px;height:48px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
            {% endif %}
        </a>
    </div>

    {# Content Area #}
    <div class="p-3 d-flex flex-column flex-grow-1" style="background: #fff;">
        <h3 style="font-size: 1rem; font-weight: 700; color: #1A1A1A; margin-bottom: 0.5rem; line-height: 1.3; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
            <a href="{{ path('sylius_shop_product_show', {'slug': product.slug, '_locale': sylius.localeCode}) }}" style="color: inherit; text-decoration: none;">
                {{ product.name }}
            </a>
        </h3>
        
        <div class="mt-auto pt-2">
            {% if cheapest_variant is not null %}
                <div style="font-size: 1.25rem; font-weight: 800; color: #E87722;">
                    {{ price|sylius_format_money(sylius.currencyCode) }}
                </div>
            {% endif %}
            
            <div class="mt-3">
                {% if cheapest_variant is not null %}
                    {% set is_out_of_stock = product.enabledVariants.empty() or (product.simple and not sylius_inventory_is_available(cheapest_variant)) %}
                    <div class="{{ is_out_of_stock ? 'cateco-product-card-out-of-stock' : '' }}">
                        {{ component('sylius_shop:product:add_to_cart_form', {
                            'product': product,
                            'variant': cheapest_variant,
                            'template': '@SyliusShop/product/common/add_to_cart_form.html.twig',
                            'key': product.id|default(random())
                        }) }}

                        {% if is_out_of_stock %}
                            <style>
                                .cateco-product-card-out-of-stock button[type="submit"] {
                                    background-color: #F5F4F0 !important;
                                    color: #A09E99 !important;
                                    cursor: not-allowed !important;
                                    pointer-events: none !important;
                                }
                            </style>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<style>
.cateco-product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.06);
}
</style>
