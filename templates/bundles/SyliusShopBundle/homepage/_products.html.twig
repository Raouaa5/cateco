{#
    Nouveautés produits - Stable Carousel with Infinite Loop
#}

{% set products = get_latest_products(16) %}

<section style="padding: 4rem 0; background-color: var(--color-bg-page); border-top: 1px solid var(--color-border); overflow: hidden;">
    <div class="container mx-auto px-4 lg:px-8">
        
        {# Header #}
        <div style="margin-bottom: 2.5rem; display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 1.5rem;">
            <div>
                <h2 style="font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; color: var(--color-text-heading); margin: 0 0 0.5rem 0; letter-spacing: -0.02em;">
                    Nouveautés produits
                </h2>
                <a href="{{ path('sylius_shop_product_index', {'slug': 'nouveaute'}) }}" style="font-size: 1rem; font-weight: 700; color: var(--color-text-heading); border-bottom: 2px solid var(--color-primary); text-decoration: none; display: inline-block; transition: color 0.2s;" onmouseover="this.style.color='var(--color-primary)'" onmouseout="this.style.color='var(--color-text-heading)'">
                    Voir tous nos produits >
                </a>
            </div>
            
            {# Carousel Navigation Arrows #}
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <button type="button" id="prev-btn" style="background: var(--color-bg-card); border: 1px solid var(--color-border); cursor: pointer; color: var(--color-text-heading); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-card); transition: all 0.2s;" onmouseover="this.style.borderColor='var(--color-primary)'; this.style.color='var(--color-primary)'" onmouseout="this.style.borderColor='var(--color-border)'; this.style.color='var(--color-text-heading)'">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width: 24px; height: 24px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" /></svg>
                </button>
                <button type="button" id="next-btn" style="background: var(--color-bg-card); border: 1px solid var(--color-border); cursor: pointer; color: var(--color-text-heading); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow-card); transition: all 0.2s;" onmouseover="this.style.borderColor='var(--color-primary)'; this.style.color='var(--color-primary)'" onmouseout="this.style.borderColor='var(--color-border)'; this.style.color='var(--color-text-heading)'">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width: 24px; height: 24px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
                </button>
            </div>
        </div>

        {# Products Carousel Container #}
        {% if products|length > 0 %}
            <div id="homepage-products-scroll-wrapper" style="position: relative; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none; padding: 1rem 0 2rem;">
                <style>#homepage-products-scroll-wrapper::-webkit-scrollbar { display: none; }</style>
                
                <div id="homepage-products-carousel" style="display: flex; gap: 1.5rem; width: max-content;">
                    {% for product in products %}
                        {% set cheapest_variant = null %}
                        {% set cheapest_price = null %}
                        {% set cheapest_currency = 'EUR' %}
                        {% for variant in product.variants %}
                            {% for pricing in variant.channelPricings %}
                                {% if pricing.price is not null %}
                                    {% if cheapest_price is null or pricing.price < cheapest_price %}
                                        {% set cheapest_price = pricing.price %}
                                        {% set cheapest_variant = variant %}
                                        {% set cheapest_currency = pricing.currencyCode|default('EUR') %}
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
                        {% endfor %}
                        
                        {# Unique class name and forced width to avoid conflicts #}
                        <div class="cateco-home-product-card" style="flex: 0 0 260px; width: 260px !important; display: flex; flex-direction: column; vertical-align: top; background: transparent;">
                            <div style="background-color: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; margin-bottom: 1rem; position: relative; width: 100%; aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; overflow: hidden; box-shadow: var(--shadow-card);">
                                {% if product.images|length > 0 %}
                                    {% set image_path = product.images.first.path %}
                                    <img src="{{ image_path[0:4] == 'http' ? image_path : asset('media/image/' ~ image_path) }}" alt="{{ product.name }}" style="width: 100%; height: 100%; object-fit: contain; mix-blend-mode: multiply;" />
                                {% else %}
                                    <div style="color: var(--color-text-muted);"><svg style="width: 48px; height: 48px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg></div>
                                {% endif %}
                            </div>
                            <div style="padding: 0 0.5rem;">
                                <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--color-text-heading); margin: 0 0 0.25rem 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    <a href="{{ path('sylius_shop_product_show', {'slug': product.slug}) }}" style="color: inherit; text-decoration: none;">{{ product.name }}</a>
                                </h3>
                                
                                <div style="margin-bottom: 1rem;">
                                    {% if cheapest_price %}
                                        <span style="font-size: 1.25rem; font-weight: 800; color: var(--color-text-heading);">{{ cheapest_price|sylius_format_money(cheapest_currency) }}</span>
                                    {% endif %}
                                </div>

                                <div class="home-add-to-cart-wrapper" style="margin-top: auto;">
                                    {{ component('sylius_shop:product:add_to_cart_form', {
                                        'product': product,
                                        'variant': cheapest_variant,
                                        'template': '@SyliusShop/product/common/add_to_cart_form.html.twig',
                                        'key': product.id|default(random())
                                    }) }}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    const scrollWrapper = document.getElementById('homepage-products-scroll-wrapper');
                    const carousel = document.getElementById('homepage-products-carousel');
                    const nextBtn = document.getElementById('next-btn');
                    const prevBtn = document.getElementById('prev-btn');
                    if (!carousel || carousel.children.length === 0) return;

                    const originalCount = {{ products|length }};
                    const itemWidth = 260 + 24; // width + gap
                    
                    // Clone items to enable smooth infinite loop
                    const items = Array.from(carousel.children);
                    items.forEach(item => carousel.appendChild(item.cloneNode(true)));
                    items.forEach(item => carousel.appendChild(item.cloneNode(true)));

                    let isAutoScrolling = true;
                    let scrollSpeed = 0.8; // px per frame
                    
                    // Set initial position to the middle set
                    scrollWrapper.scrollLeft = itemWidth * originalCount;

                    function animate() {
                        if (isAutoScrolling) {
                            scrollWrapper.scrollLeft += scrollSpeed;
                            
                            // Seamless loop back to middle
                            if (scrollWrapper.scrollLeft >= itemWidth * originalCount * 2) {
                                scrollWrapper.scrollLeft -= itemWidth * originalCount;
                            }
                        }
                        requestAnimationFrame(animate);
                    }

                    nextBtn.addEventListener('click', () => {
                        isAutoScrolling = false;
                        scrollWrapper.scrollBy({ left: itemWidth, behavior: 'smooth' });
                        setTimeout(() => { isAutoScrolling = true; }, 1000);
                    });

                    prevBtn.addEventListener('click', () => {
                        isAutoScrolling = false;
                        scrollWrapper.scrollBy({ left: -itemWidth, behavior: 'smooth' });
                        setTimeout(() => { isAutoScrolling = true; }, 1000);
                    });

                    scrollWrapper.addEventListener('mouseenter', () => isAutoScrolling = false);
                    scrollWrapper.addEventListener('mouseleave', () => isAutoScrolling = true);
                    
                    requestAnimationFrame(animate);
                });
            </script>
        {% else %}
            <div style="text-align: center; padding: 5rem 0; color: #6b7280;"><p>Aucun produit disponible.</p></div>
        {% endif %}
    </div>
</section>
