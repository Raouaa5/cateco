{#
    Catalogue Section — White bg, title left, teal card right with small tilted floating image
    Uses inline styles for rotation/sizing to avoid Tailwind purge issues
#}

<section style="background-color: #F5F0E8; border-radius: 24px; margin: 10px 1.5rem 40px; overflow: hidden; padding: 5rem 0;">
    <div class="container mx-auto px-6 lg:px-12" style="max-width: 1280px; margin: 0 auto;">
        <div style="display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:4rem; width: 100%;">

            {# ── Left: Text & CTA ── #}
            <div style="flex:1; min-width:300px; max-width:540px;">
                <p style="color: #E87722; font-weight: 800; font-size: 0.9rem; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 1rem;">
                    NOS CATALOGUES
                </p>
                <h2 style="font-size:clamp(2.5rem,5vw,3.5rem); font-weight:800; color:var(--color-text-heading); font-family: var(--font-base); line-height:1.1; margin:0 0 1.5rem;">
                    Feuilletez notre <br>dernier <span style="color: #E87722;">catalogue</span><br> en ligne !
                </h2>
                
                <p style="color: var(--color-text-body); font-size: 1.1rem; line-height: 1.6; margin-bottom: 2.5rem;">
                    Découvrez toutes nos offres et promotions du<br> moment. Mis à jour régulièrement pour vous.
                </p>

                <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 3.5rem;">
                    {# Outline button with book icon matching mockup #}
                    <a href="https://www.calameo.com/read/007260152f5b472bbd8b8" target="_blank" style="background-color: transparent; color: var(--color-text-heading); padding: 0.8rem 1.5rem; border-radius: 12px; font-weight: 700; text-decoration: none; border: 1px solid rgba(0,0,0,0.1); display: flex; align-items: center; gap: 0.5rem; transition: background-color 0.2s;" onmouseover="this.style.backgroundColor='rgba(0,0,0,0.03)'" onmouseout="this.style.backgroundColor='transparent'">
                        <svg style="width: 20px; height: 20px; color: var(--color-text-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                        Consulter le catalogue
                    </a>
                </div>

                <div style="display: flex; gap: 3rem; border-top: 1px solid rgba(0,0,0,0.05); padding-top: 2rem;">
                    <div>
                        <div style="font-size: 2rem; font-weight: 800; color: var(--color-text-heading); display: flex; align-items: center;">
                            88<span style="color: #E87722;">+</span>
                        </div>
                        <div style="color: var(--color-text-body); font-size: 0.9rem;">Pages de produits</div>
                    </div>
                    <div>
                        <div style="font-size: 2rem; font-weight: 800; color: var(--color-text-heading); display: flex; align-items: center;">
                            100<span style="color: #E87722;">%</span>
                        </div>
                        <div style="color: var(--color-text-body); font-size: 0.9rem;">Gratuit en ligne</div>
                    </div>
                </div>
            </div>

            {# ── Right: Single Large Card ── #}
            <div style="flex:1; min-width:320px; position:relative; display:flex; justify-content: center; padding: 2rem 0;">
                
                {# Main Card #}
                <a href="https://www.calameo.com/read/007260152f5b472bbd8b8" target="_blank" style="
                    background-color: #ffffff;
                    border-radius: 12px;
                    width: 360px;
                    padding: 2rem 1.5rem;
                    text-align: center;
                    text-decoration: none;
                    box-shadow: 0 4px 20px rgba(0,0,0,0.09);
                    transition: transform 0.3s ease;
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                " onmouseover="this.style.transform='translateY(-8px)'" onmouseout="this.style.transform='translateY(0)'">
                    
                    <img src="{{ asset('assets/shop/images/catalogue.png') }}"
                         alt="Catalogue Catéco"
                         style="width:100%; height:auto; max-height: 280px; object-fit:contain; margin-bottom: 1.5rem; border-radius: 8px;">
                         
                    <h3 style="color:var(--color-text-heading); font-size:1.4rem; font-weight:800; margin:0 0 0.5rem;">Catalogue Catéco</h3>
                    <p style="color:var(--color-text-body); font-size: 1rem; margin: 0 0 0.5rem;">Catalogue 88 pages</p>
                </a>

            </div>

        </div>
    </div>
</section>
