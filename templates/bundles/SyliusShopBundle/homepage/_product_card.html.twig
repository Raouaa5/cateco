{#
    Product Card Component - Used by homepage products grid
    This template is rendered through Sylius Twig Hooks
#}

{% if product %}
    <div class="bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow overflow-hidden">
        {# Image Container #}
        <div class="w-full h-64 bg-gray-100 relative">
            {% if product.images|length > 0 %}
                {% set image = product.images.first %}
                <img 
                    src="{{ image.path|imagine_filter('sylius_medium') }}" 
                    alt="{{ product.name }}"
                    class="w-full h-full object-cover"
                />
            {% else %}
                <div class="flex items-center justify-center h-full text-gray-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                </div>
            {% endif %}
            
            {# Badge #}
            {% if product.isNew %}
                <span class="absolute top-2 left-2 px-2 py-1 bg-orange-500 text-white text-xs font-bold rounded">
                    Nouveau
                </span>
            {% endif %}
        </div>

        {# Content #}
        <div class="p-4">
            {# Name #}
            <h3 class="font-medium text-gray-900 mb-2 line-clamp-2">
                <a href="{{ path('sylius_shop_product_show', {'slug': product.slug}) }}" class="hover:text-orange-500 transition-colors">
                    {{ product.name }}
                </a>
            </h3>

            {# Price #}
            <div class="mb-3">
                {% if product.cheapestPrice %}
                    <span class="text-lg font-bold text-orange-500">
                        {{ product.cheapestPrice|sylius_format_money(product.cheapestPrice.currencyCode) }}
                    </span>
                {% elseif product.price %}
                    <span class="text-lg font-bold text-orange-500">
                        {{ product.price|sylius_format_money(product.currencyCode) }}
                    </span>
                {% endif %}
            </div>

            {# Add to Cart #}
            <form method="post" action="{{ path('sylius_shop_cart_item_add', {'productId': product.id}) }}">
                <input type="hidden" name="sylius_cart_item[quantity]" value="1">
                <button 
                    type="submit"
                    class="w-full py-2 bg-gray-800 hover:bg-orange-500 text-white font-medium rounded transition-colors"
                >
                    Ajouter au panier
                </button>
            </form>
        </div>
    </div>
{% endif %}
