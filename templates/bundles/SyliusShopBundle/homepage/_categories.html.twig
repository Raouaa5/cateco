{#
    Categories Section — Teal bg, modern grid matching cateco.fr style
    Uses inline styles for grid row height to avoid Tailwind purge issues
#}

{# Map category slugs (last segment) to local static images — based on real DB slugs #}
{# Map category slugs (last segment) to local static images — based on real DB slugs #}
{% set categoryImages = {
    'nouveaute':         'assets/shop/images/Nouveautés.png',
    '1e-2e-3e':          'assets/shop/images/petits-prix.png',
    'jardin':             'assets/shop/images/jardinage.jpg',
    'maison':            'assets/shop/images/meubles2.jpg',
    'plein-air':          'assets/shop/images/plein-air2.jpg',
    'anti-insectes':      'assets/shop/images/anti-insectes.jpg',
    'tentes-baches':      'assets/shop/images/tentes&baches.jpg',
    'bricolage-auto':    'assets/shop/images/bricolage-roues.jpg',
    'sport-bien-etre':    'assets/shop/images/Sport-Bien-être.jpg'
} %}

{# Desired order based on slugs #}
{% set sortedSlugs = [
    'nouveaute',
    '1e-2e-3e',
    'jardin',
    'maison',
    'plein-air',
    'anti-insectes',
    'tentes-baches',
    'bricolage-auto',
    'sport-bien-etre'
] %}

<section style="background-color:#17716c; padding:4rem 0;">
    <div class="container mx-auto px-4 lg:px-8">

        {# Section Header #}
        <h2 style="font-size:clamp(1.6rem,3vw,2.5rem); font-weight:800; color:#fff; margin:0 0 2.5rem 0; letter-spacing:-0.5px;">
            Nos différentes catégories de produits
        </h2>

        {# Categories Grid #}
        <div style="
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.25rem;
            grid-auto-rows: 260px;
        " class="categories-grid">

            {% set currentIdx = 0 %}
            {% for targetSlug in sortedSlugs %}
                {# Find the category object that matches the targetSlug #}
                {% set category = null %}
                {% for cat in categories %}
                    {% if cat.slug|split('/')|last == targetSlug %}
                        {% set category = cat %}
                    {% endif %}
                {% endfor %}

                {% if category %}
                    {% set slugKey = targetSlug %}
                    {% set imgSrc = categoryImages[slugKey] ?? 'assets/shop/images/plein-air2.jpg' %}

                    {# 4th card (maison) typically spans 2 columns in the reference layout #}
                    <a href="{{ path('sylius_shop_product_index', {'slug': category.slug, '_locale': sylius.localeCode}) }}"
                       class="category-card"
                       style="
                           position:relative;
                           display:block;
                           border-radius:1.25rem;
                           overflow:hidden;
                           text-decoration:none;
                           box-shadow:0 4px 20px rgba(0,0,0,0.2);
                           transition:transform 0.35s ease, box-shadow 0.35s ease;
                           {% if currentIdx == 3 %}grid-column: span 2;{% endif %}
                       "
                       onmouseover="this.style.transform='translateY(-6px) scale(1.01)'; this.style.boxShadow='0 16px 40px rgba(0,0,0,0.35)'"
                       onmouseout="this.style.transform=''; this.style.boxShadow='0 4px 20px rgba(0,0,0,0.2)'">

                        {% if category.images|length > 0 %}
                            {% set cat_image_path = category.images.first.path %}
                            <img src="{{ cat_image_path[0:4] == 'http' ? cat_image_path : asset('media/image/' ~ cat_image_path) }}"
                                 alt="{{ category.name }}"
                                 style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform 0.6s ease;"
                                 class="cat-img"
                                 onerror="this.src='/assets/shop/images/no-image.png';">
                        {% else %}
                            <img src="{{ asset(imgSrc) }}"
                                 alt="{{ category.name }}"
                                 style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform 0.6s ease;"
                                 class="cat-img">
                        {% endif %}

                        {# Dark gradient overlay #}
                        <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.1) 55%, transparent 100%);"></div>

                        {# Category label + CTA #}
                        <div style="position:absolute;bottom:0;left:0;width:100%;padding:1.25rem 1.25rem 1rem;">
                            <h3 style="color:#fff;font-size:1.15rem;font-weight:700;margin:0 0 0.5rem;text-shadow:0 1px 4px rgba(0,0,0,0.4);">
                                {{ category.name }}
                            </h3>
                            <span style="display:inline-flex;align-items:center;gap:0.3rem;background:#f5c518;color:#222;font-size:0.75rem;font-weight:700;padding:0.3rem 0.75rem;border-radius:999px;letter-spacing:0.03em;">
                                Découvrir la catégorie
                                <svg xmlns="http://www.w3.org/2000/svg" style="width:12px;height:12px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/>
                                </svg>
                            </span>
                        </div>
                    </a>
                    {% set currentIdx = currentIdx + 1 %}
                {% endif %}
            {% endfor %}

        </div>
    </div>
</section>

<style>
    .category-card:hover .cat-img {
        transform: scale(1.07);
    }
    @media (max-width: 768px) {
        .categories-grid {
            grid-template-columns: 1fr !important;
            grid-auto-rows: 220px !important;
        }
        .categories-grid a[style*="span 2"] {
            grid-column: span 1 !important;
        }
    }
    @media (min-width: 769px) and (max-width: 1024px) {
        .categories-grid {
            grid-template-columns: repeat(2, 1fr) !important;
        }
    }
</style>
