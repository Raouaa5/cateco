{#
    Trust Indicators Section - 4 columns (Garantie, Paiement, Livraison, Depuis 2003)
#}

<section style="background-color: var(--color-bg-page); padding: 3rem 0; border-top: 1px solid var(--color-border);">
    <div class="container mx-auto px-4 lg:px-8">
        
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2rem;">
            
            {# 1. Garantie #}
            <div style="display: flex; flex-direction: column; align-items: center; text-align: center; gap: 1rem;">
                <div style="color: var(--color-primary); display: flex; align-items: center; justify-content: center; width: 48px; height: 48px; flex-shrink: 0;">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width: 32px; height: 32px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <h4 style="font-weight: 700; color: var(--color-text-heading); font-size: 1rem; margin: 0 0 0.25rem 0;">Une garantie de 2 ans</h4>
                    <p style="color: var(--color-text-muted); font-size: 0.875rem; margin: 0;">Selon la réglementation en vigueur</p>
                </div>
            </div>

            {# 2. Paiement #}
            <div style="display: flex; flex-direction: column; align-items: center; text-align: center; gap: 1rem;">
                <div style="color: var(--color-primary); display: flex; align-items: center; justify-content: center; width: 48px; height: 48px; flex-shrink: 0;">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width: 32px; height: 32px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                    </svg>
                </div>
                <div>
                    <h4 style="font-weight: 700; color: var(--color-text-heading); font-size: 1rem; margin: 0 0 0.25rem 0;">Paiement possible en plusieurs fois sans frais</h4>
                </div>
            </div>

            {# 3. Livraison #}
            <div style="display: flex; flex-direction: column; align-items: center; text-align: center; gap: 1rem;">
                <div style="color: var(--color-primary); display: flex; align-items: center; justify-content: center; width: 48px; height: 48px; flex-shrink: 0;">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width: 32px; height: 32px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                </div>
                <div>
                    <h4 style="font-weight: 700; color: var(--color-text-heading); font-size: 1rem; margin: 0 0 0.25rem 0;">Mise à disposition rapide</h4>
                    <p style="color: var(--color-text-muted); font-size: 0.875rem; margin: 0;">Sur tout notre catalogue</p>
                </div>
            </div>

            {# 4. Depuis 2003 #}
            <div style="display: flex; flex-direction: column; align-items: center; text-align: center; gap: 1rem;">
                <div style="color: var(--color-primary); display: flex; align-items: center; justify-content: center; width: 48px; height: 48px; flex-shrink: 0;">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width: 32px; height: 32px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <h4 style="font-weight: 700; color: var(--color-text-heading); font-size: 1rem; margin: 0 0 0.25rem 0;">Depuis 2003</h4>
                    <p style="color: var(--color-text-muted); font-size: 0.875rem; margin: 0;">à votre service !</p>
                </div>
            </div>

        </div>

    </div>
</section>
