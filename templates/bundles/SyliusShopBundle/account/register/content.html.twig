{% set form = hookable_metadata.context.form %}

<style>
body { background: #F5F4F0 !important; }

.cateco-register-wrap {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 20px 16px 12px;
}

.cateco-register-card {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    border-radius: 16px;
    overflow: hidden;
    border: 0.5px solid #E0DDD5;
    width: 100%;
    max-width: 980px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.08);
}

/* ── Left panel ── */
.cateco-reg-left {
    background: #1A1A1A;
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
}
.cateco-reg-left .deco-circle-1 {
    position: absolute; width: 280px; height: 280px;
    border-radius: 50%; background: #E87722; opacity: 0.08;
    top: -80px; right: -80px; pointer-events: none;
}
.cateco-reg-left .deco-circle-2 {
    position: absolute; width: 200px; height: 200px;
    border-radius: 50%; background: #E87722; opacity: 0.06;
    bottom: -60px; left: -60px; pointer-events: none;
}

.reg-logo { text-decoration: none; display: inline-block; margin-bottom: 36px; }

.reg-left-title {
    font-size: 26px; font-weight: 800; color: #fff; line-height: 1.25; margin: 0 0 10px;
}
.reg-left-title em { color: #E87722; font-style: normal; }

.reg-left-sub {
    font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.6; margin: 0 0 24px;
}

.reg-perks { list-style: none; padding: 0; margin: 0 0 28px; }
.reg-perks li {
    display: flex; align-items: center; gap: 10px;
    font-size: 13px; font-weight: 600;
    color: rgba(255,255,255,0.55); margin-bottom: 12px;
}
.reg-perks li::before {
    content: ''; flex-shrink: 0;
    width: 6px; height: 6px; border-radius: 50%; background: #E87722;
}

/* ── Step indicator ── */
.reg-step-indicator {
    margin-bottom: 24px;
}
.reg-step-label {
    font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.4);
    letter-spacing: 1px; text-transform: uppercase; margin-bottom: 10px;
}
.reg-step-dots {
    display: flex; gap: 8px; align-items: center;
}
.reg-step-dot {
    height: 4px; border-radius: 99px;
    transition: width 0.35s ease, background 0.35s ease;
}
.reg-step-dot.active { width: 28px; background: #E87722; }
.reg-step-dot.done   { width: 16px; background: rgba(232,119,34,0.5); }
.reg-step-dot.pending{ width: 16px; background: rgba(255,255,255,0.15); }

.reg-step-text {
    font-size: 12px; font-weight: 600;
    color: rgba(255,255,255,0.5); margin-top: 10px;
}
.reg-step-text span { color: #E87722; }

/* ── Frosted login card ── */
.reg-login-card {
    background: rgba(255,255,255,0.05);
    border: 0.5px solid rgba(255,255,255,0.1);
    border-radius: 12px; padding: 16px 18px;
    display: flex; justify-content: space-between; align-items: center; gap: 12px;
}
.reg-login-card-text { font-size: 13px; color: rgba(255,255,255,0.55); font-weight: 500; }
.reg-login-card-text strong { display: block; color: #fff; font-size: 13px; font-weight: 700; margin-bottom: 2px; }
.btn-reg-login-small {
    flex-shrink: 0; background: transparent; color: #E87722 !important;
    font-size: 11px; font-weight: 800; border-radius: 8px; padding: 9px 16px;
    text-decoration: none; border: 1.5px solid #E87722; cursor: pointer;
    white-space: nowrap; transition: background 0.2s, color 0.2s;
}
.btn-reg-login-small:hover { background: #E87722; color: #fff !important; }

/* ── Right panel ── */
.cateco-reg-right {
    background: #fff; padding: 44px 48px;
    display: flex; flex-direction: column;
}

.reg-eyebrow {
    display: flex; align-items: center; gap: 10px;
    color: #E87722; font-size: 11px; font-weight: 800;
    letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 10px;
}
.reg-eyebrow::before {
    content: ''; display: block; width: 24px; height: 2px;
    background: #E87722; border-radius: 2px;
}

.reg-right-title { font-size: 24px; font-weight: 800; color: #1A1A1A; margin: 0 0 4px; }
.reg-right-sub { font-size: 13px; color: #9CA3AF; margin: 0 0 22px; }

/* ── Progress bar (top of right panel) ── */
.reg-progress-bar-wrap {
    height: 3px; background: #F0EDE7; border-radius: 99px;
    margin-bottom: 24px; overflow: hidden;
}
.reg-progress-bar {
    height: 100%; background: #E87722; border-radius: 99px;
    transition: width 0.4s ease;
}

/* ── Section headers ── */
.reg-section-label {
    font-size: 11px; font-weight: 800; letter-spacing: 1px;
    text-transform: uppercase; color: #1A1A1A;
    margin: 0 0 16px; padding-bottom: 8px;
    border-bottom: 1.5px solid #F0EDE7;
    display: flex; align-items: center; gap: 8px;
}
.reg-section-label svg { color: #E87722; }

/* ── Two-column row ── */
.reg-row-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

/* ── Input groups ── */
.reg-field { margin-bottom: 14px; }
.reg-field > label {
    display: block; font-size: 12px; font-weight: 700;
    color: #374151; margin-bottom: 5px;
}
.reg-field > label .req { color: #E87722; margin-left: 2px; }

.reg-input-wrap { position: relative; display: flex; align-items: center; }
.reg-input-wrap .field-icon {
    position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
    pointer-events: none; color: #9CA3AF; display: flex; z-index: 1; transition: color 0.2s;
}
.reg-input-wrap:focus-within .field-icon { color: #E87722; }

/* ── Header row (eyebrow + step badge) ── */
.reg-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
}
.reg-header-row .reg-eyebrow { margin-bottom: 0; }
.reg-step-badge {
    font-size: 11px;
    font-weight: 700;
    color: #E87722;
    background: rgba(232,119,34,0.08);
    border: 1px solid rgba(232,119,34,0.2);
    border-radius: 99px;
    padding: 4px 12px;
    white-space: nowrap;
}

.reg-input-wrap input[type="text"],
.reg-input-wrap input[type="email"],
.reg-input-wrap input[type="tel"],
.reg-input-wrap input[type="password"] {
    width: 100%; height: 42px;
    border: 1.5px solid #E0DDD5; border-radius: 9px;
    padding: 0 12px 0 38px; font-size: 13px; color: #1A1A1A;
    background: #fff !important; outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
    -webkit-box-shadow: 0 0 0 1000px #fff inset !important;
    -webkit-text-fill-color: #1A1A1A !important;
    box-shadow: none; appearance: none; -webkit-appearance: none;
}
.reg-input-wrap input::placeholder { color: #9CA3AF !important; font-weight: 400; }
.reg-input-wrap input::-webkit-input-placeholder { color: #9CA3AF !important; }
.reg-input-wrap input::-moz-placeholder { color: #9CA3AF !important; opacity: 1; }
.reg-input-wrap input:-ms-input-placeholder { color: #9CA3AF !important; }
.cateco-reg-right .form-control::placeholder { color: #9CA3AF !important; }
.cateco-reg-right .form-control::-webkit-input-placeholder { color: #9CA3AF !important; }
.cateco-reg-right .form-control::-moz-placeholder { color: #9CA3AF !important; opacity: 1; }

.reg-input-wrap input:focus {
    border-color: #E87722 !important;
    box-shadow: 0 0 0 3px rgba(232,119,34,0.1) !important;
    -webkit-box-shadow: 0 0 0 3px rgba(232,119,34,0.1), 0 0 0 1000px #fff inset !important;
    outline: none;
}

/* Eye toggle */
.reg-input-wrap .eye-toggle {
    position: absolute; right: 11px; top: 50%; transform: translateY(-50%);
    background: none; border: none; cursor: pointer;
    color: #9CA3AF; padding: 0; display: flex; transition: color 0.2s; z-index: 1;
}
.reg-input-wrap .eye-toggle:hover { color: #E87722; }

/* ── Newsletter checkbox ── */
.reg-newsletter-label {
    display: flex; align-items: center; gap: 9px; cursor: pointer;
    font-size: 13px; color: #555; font-weight: 500; user-select: none; margin-top: 4px;
}
.reg-newsletter-label input[type="checkbox"] {
    position: absolute; opacity: 0; width: 16px; height: 16px; margin: 0; cursor: pointer;
}
.reg-cb-box {
    flex-shrink: 0; width: 16px; height: 16px;
    border: 1.5px solid #E0DDD5; border-radius: 4px; background: #fff;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s, border-color 0.15s;
}
.reg-newsletter-label input[type="checkbox"]:checked ~ .reg-cb-box { background: #E87722; border-color: #E87722; }
.reg-newsletter-label input[type="checkbox"]:checked ~ .reg-cb-box svg { display: block; }
.reg-cb-box svg { display: none; }

/* ── Step buttons row ── */
.reg-step-btns {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 24px; gap: 12px;
}

.btn-reg-back {
    display: flex; align-items: center; gap: 6px;
    background: none; border: 1.5px solid #E0DDD5;
    color: #555; font-size: 13px; font-weight: 700;
    border-radius: 10px; padding: 11px 20px;
    cursor: pointer; transition: border-color 0.2s, color 0.2s;
}
.btn-reg-back:hover { border-color: #E87722; color: #E87722; }

.btn-reg-continue {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #E87722;
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    border-radius: 9px;
    padding: 10px 20px;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
    width: auto;
    flex: none;
}
.btn-reg-continue:hover { background: #C85F00; }

.btn-reg-primary {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #E87722;
    color: #fff;
    font-size: 14px;
    font-weight: 800;
    border-radius: 10px;
    padding: 13px 20px;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
}
.btn-reg-primary:hover { background: #C85F00; }

/* ── Validation error highlight ── */
.reg-input-wrap input.field-error { border-color: #FECACA !important; }
.reg-field-err { font-size: 11px; color: #DC2626; margin-top: 4px; display: none; }
.reg-field-err.show { display: block; }

/* ── Step panels ── */
#reg-step-2 { display: none; }

/* ── Override Bootstrap labels ── */
.cateco-reg-right label { color: #374151 !important; }
.cateco-reg-right .form-group { all: unset; display: block; width: 100%; }
.cateco-reg-right .invalid-feedback { font-size: 11px; color: #DC2626; margin-top: 4px; }

/* ── Responsive ── */
@media (max-width: 720px) {
    .cateco-register-card { grid-template-columns: 1fr; }
    .cateco-reg-left { display: none; }
    .cateco-reg-right { padding: 36px 24px; }
    .reg-row-2col { grid-template-columns: 1fr; }
}
</style>

<div class="cateco-register-wrap">
    <div class="cateco-register-card">

        {# ── LEFT PANEL ── #}
        <div class="cateco-reg-left">
            <div class="deco-circle-1"></div>
            <div class="deco-circle-2"></div>

            <div>
                <a href="{{ path('sylius_shop_homepage') }}" class="reg-logo">
                    <img src="{{ asset('assets/shop/images/logo2.png') }}" alt="Catéco" style="height: 55px; width: auto; object-fit: contain;">
                </a>

                <p class="reg-left-title">
                    Créez votre<br>espace <em>Catéco</em>
                </p>
                <p class="reg-left-sub">
                    Rejoignez des milliers de clients et profitez<br>
                    de tous les avantages de votre espace personnel.
                </p>

                <ul class="reg-perks">
                    <li>Suivez vos commandes en temps réel</li>
                    <li>Accédez à vos factures et historique</li>
                    <li>Profitez de -10% avec le Club Catéco</li>
                    <li>Gérez vos adresses de livraison</li>
                    <li>Recevez nos offres exclusives</li>
                </ul>


            </div>

            <div class="reg-login-card">
                <div class="reg-login-card-text">
                    <strong>Déjà un compte ?</strong>
                    Connectez-vous à votre espace
                </div>
                <a href="{{ path('sylius_shop_login') }}" class="btn-reg-login-small">Se connecter</a>
            </div>
        </div>

        {# ── RIGHT PANEL ── #}
        <div class="cateco-reg-right">
            <div class="reg-header-row">
                <div class="reg-eyebrow" id="reg-eyebrow-text">Inscription</div>
                <div class="reg-step-badge" id="reg-step-badge">Étape <span id="reg-step-num">1</span> sur 2</div>
            </div>
            <h1 class="reg-right-title">Créer un compte</h1>
            <p class="reg-right-sub" id="reg-subtitle">Remplissez le formulaire pour rejoindre Catéco</p>

            {# Progress bar #}
            <div class="reg-progress-bar-wrap">
                <div class="reg-progress-bar" id="reg-progress-bar" style="width: 50%"></div>
            </div>

            {% form_theme form '@SyliusShop/form/theme.html.twig' %}
            {{ form_start(form, {
                'action': path('sylius_shop_register'),
                'attr': {'novalidate': 'novalidate', 'id': form.vars.id, 'class': 'cateco-reg-form'}
            }) }}
            {{ form_row(form._token) }}

                {# ══════════ STEP 1 ══════════ #}
                <div id="reg-step-1">
                    <div class="reg-section-label">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        Informations personnelles
                    </div>

                    <div class="reg-row-2col">
                        <div class="reg-field">
                            <label for="reg_firstName">Prénom <span class="req">*</span></label>
                            <div class="reg-input-wrap">
                                <span class="field-icon">
                                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                </span>
                                {{ form_widget(form.firstName, {'id': 'reg_firstName', 'attr': {'placeholder': 'Votre prénom', 'class': 'cateco-reg-input'}}) }}
                            </div>
                            {{ form_errors(form.firstName) }}
                            <div class="reg-field-err" id="err-firstName">Ce champ est requis.</div>
                        </div>
                        <div class="reg-field">
                            <label for="reg_lastName">Nom <span class="req">*</span></label>
                            <div class="reg-input-wrap">
                                <span class="field-icon">
                                    <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                </span>
                                {{ form_widget(form.lastName, {'id': 'reg_lastName', 'attr': {'placeholder': 'Votre nom', 'class': 'cateco-reg-input'}}) }}
                            </div>
                            {{ form_errors(form.lastName) }}
                            <div class="reg-field-err" id="err-lastName">Ce champ est requis.</div>
                        </div>
                    </div>

                    <div class="reg-field">
                        <label for="reg_email">Adresse e-mail <span class="req">*</span></label>
                        <div class="reg-input-wrap">
                            <span class="field-icon">
                                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                            </span>
                            {{ form_widget(form.email, {'id': 'reg_email', 'attr': {'placeholder': 'votre@email.com', 'class': 'cateco-reg-input'}}) }}
                        </div>
                        {{ form_errors(form.email) }}
                        <div class="reg-field-err" id="err-email">Veuillez entrer un e-mail valide.</div>
                    </div>

                    <div class="reg-field">
                        <label for="reg_phone">Téléphone</label>
                        <div class="reg-input-wrap">
                            <span class="field-icon">
                                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                            </span>
                            {{ form_widget(form.phoneNumber, {'id': 'reg_phone', 'attr': {'placeholder': 'Votre numéro de téléphone', 'class': 'cateco-reg-input'}}) }}
                        </div>
                        {{ form_errors(form.phoneNumber) }}
                    </div>

                    <div class="reg-field">
                        <label class="reg-newsletter-label" for="reg_newsletter">
                            <input type="checkbox" id="reg_newsletter" name="{{ form.subscribedToNewsletter.vars.full_name }}" value="1"{% if form.subscribedToNewsletter.vars.data %} checked{% endif %}>
                            <span class="reg-cb-box">
                                <svg width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="#fff" stroke-width="3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                            </span>
                            S'abonner à la newsletter
                        </label>
                    </div>

                    {# Continue button - compact, right-aligned #}
                    <div style="display:flex; justify-content:flex-end; margin-top:20px;">
                        <button type="button" class="btn-reg-continue" id="btn-continue-step1" onclick="regGoStep2()">
                            Continuer
                            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                        </button>
                    </div>
                </div>

                {# ══════════ STEP 2 ══════════ #}
                <div id="reg-step-2">
                    <div class="reg-section-label">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                        Informations d'identification
                    </div>

                    <div class="reg-field">
                        <label for="reg_password">Mot de passe <span class="req">*</span></label>
                        <div class="reg-input-wrap">
                            <span class="field-icon">
                                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                            </span>
                            {{ form_widget(form.user.plainPassword.first, {'id': 'reg_password', 'attr': {'placeholder': 'Votre mot de passe', 'class': 'cateco-reg-input'}}) }}
                            <button type="button" class="eye-toggle" onclick="toggleRegPassword('reg_password','eye-icon-pass')" aria-label="Afficher/masquer">
                                <svg id="eye-icon-pass" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                            </button>
                        </div>
                        {{ form_errors(form.user.plainPassword.first) }}
                        <div class="reg-field-err" id="err-password">Ce champ est requis.</div>
                    </div>

                    <div class="reg-field">
                        <label for="reg_password_confirm">Confirmation <span class="req">*</span></label>
                        <div class="reg-input-wrap">
                            <span class="field-icon">
                                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                            </span>
                            {{ form_widget(form.user.plainPassword.second, {'id': 'reg_password_confirm', 'attr': {'placeholder': 'Confirmez le mot de passe', 'class': 'cateco-reg-input'}}) }}
                            <button type="button" class="eye-toggle" onclick="toggleRegPassword('reg_password_confirm','eye-icon-confirm')" aria-label="Afficher/masquer">
                                <svg id="eye-icon-confirm" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                            </button>
                        </div>
                        {{ form_errors(form.user.plainPassword.second) }}
                        <div class="reg-field-err" id="err-confirm">Ce champ est requis.</div>
                    </div>

                    <div class="reg-step-btns">
                        <button type="button" class="btn-reg-back" onclick="regGoStep1()">
                            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                            Retour
                        </button>
                        <button type="submit" class="btn-reg-primary" id="register-button">
                            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
                            Créer mon compte
                        </button>
                    </div>
                </div>

            {{ form_end(form, {'render_rest': false}) }}
        </div>

    </div>
</div>

<script>
function regGoStep2() {
    var ok = true;

    // Validate step 1 fields
    var fn = document.getElementById('reg_firstName');
    var ln = document.getElementById('reg_lastName');
    var em = document.getElementById('reg_email');

    [['reg_firstName','err-firstName'], ['reg_lastName','err-lastName']].forEach(function(pair) {
        var el = document.getElementById(pair[0]);
        var err = document.getElementById(pair[1]);
        if (!el.value.trim()) {
            el.classList.add('field-error');
            err.classList.add('show');
            ok = false;
        } else {
            el.classList.remove('field-error');
            err.classList.remove('show');
        }
    });

    // Email check
    var emailEl = document.getElementById('reg_email');
    var emailErr = document.getElementById('err-email');
    var emailOk = emailEl.value.trim() && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value.trim());
    if (!emailOk) {
        emailEl.classList.add('field-error');
        emailErr.classList.add('show');
        ok = false;
    } else {
        emailEl.classList.remove('field-error');
        emailErr.classList.remove('show');
    }

    if (!ok) return;

    // Transition to step 2
    document.getElementById('reg-step-1').style.display = 'none';
    document.getElementById('reg-step-2').style.display = 'block';
    document.getElementById('reg-progress-bar').style.width = '100%';

    // Update step badge in right panel
    document.getElementById('reg-step-num').textContent = '2';
    document.getElementById('reg-subtitle').textContent = 'Choisissez un mot de passe sécurisé';

    // Focus first password field
    document.getElementById('reg_password').focus();
}

function regGoStep1() {
    document.getElementById('reg-step-2').style.display = 'none';
    document.getElementById('reg-step-1').style.display = 'block';
    document.getElementById('reg-progress-bar').style.width = '50%';

    document.getElementById('reg-step-num').textContent = '1';
    document.getElementById('reg-subtitle').textContent = 'Remplissez le formulaire pour rejoindre Catéco';
}

function toggleRegPassword(inputId, iconId) {
    var input = document.getElementById(inputId);
    var icon = document.getElementById(iconId);
    if (!input) return;
    if (input.type === 'password') {
        input.type = 'text';
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a9.956 9.956 0 012.293-3.95M9.88 9.88A3 3 0 0015 12m0 0a3 3 0 01-5.12 2.12M15 12L9 18M3 3l18 18"/>';
    } else {
        input.type = 'password';
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>';
    }
}

// If server returned validation errors on step 2 fields, jump to step 2 automatically
document.addEventListener('DOMContentLoaded', function() {
    var passErr = document.querySelector('#reg-step-2 .invalid-feedback, #reg-step-2 .form-error-message');
    if (passErr && passErr.textContent.trim()) {
        regGoStep2ForceNoValidate();
    }
});

function regGoStep2ForceNoValidate() {
    document.getElementById('reg-step-1').style.display = 'none';
    document.getElementById('reg-step-2').style.display = 'block';
    document.getElementById('reg-progress-bar').style.width = '100%';
    document.getElementById('reg-step-num').textContent = '2';
    document.getElementById('reg-subtitle').textContent = 'Choisissez un mot de passe sécurisé';
}
</script>
