{% extends '@SyliusShop/shared/layout/base.html.twig' %}

{% block title %}Ma Wishlist — Catéco{% endblock %}

{% block content %}
<div style="background: #F5F4F0; min-height: 60vh; padding: 3rem 0;">
    <div style="max-width: 1100px; margin: 0 auto; padding: 0 1.5rem;">

        {# Page header #}
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
            <div style="display: flex; align-items: center; gap: 1rem;">
                <div style="background: #E87722; width: 42px; height: 42px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <svg width="22" height="22" fill="white" viewBox="0 0 24 24">
                        <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                </div>
                <div>
                    <h1 style="font-size: 1.6rem; font-weight: 800; color: #1A1A1A; margin: 0;">Ma Wishlist</h1>
                    <span style="color: #767676; font-size: 0.9rem;">{{ items|length }} article{{ items|length != 1 ? 's' : '' }}</span>
                </div>
            </div>

            {% if items|length > 0 %}
                <div style="display: flex; gap: 1rem;">
                    <form method="POST" action="{{ path('app_wishlist_clear') }}" style="margin: 0;" onsubmit="return confirm('Êtes-vous sûr de vouloir vider votre wishlist ?');">
                        <button type="submit" style="background: #fff; border: 1px solid #D0CCC5; border-radius: 8px; padding: 0.75rem 1.25rem; font-weight: 600; color: #767676; display: flex; align-items: center; gap: 0.5rem; transition: background 0.2s; cursor: pointer;" onmouseover="this.style.background='#F5F4F0'" onmouseout="this.style.background='#fff'">
                            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                            Vider la liste
                        </button>
                    </form>
                    
                    <form method="POST" action="{{ path('app_wishlist_add_all_to_cart') }}" style="margin: 0;">
                        <button type="submit" style="background: #E87722; color: #fff; border: none; border-radius: 8px; padding: 0.75rem 1.25rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem; transition: background 0.2s; cursor: pointer;" onmouseover="this.style.background='#C85A00'" onmouseout="this.style.background='#E87722'">
                            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
                            Tout ajouter au panier
                        </button>
                    </form>
                </div>
            {% endif %}
        </div>

        {% if items is empty %}
            {# Empty state #}
            <div style="background: #fff; border-radius: 16px; padding: 4rem 2rem; text-align: center; border: 1px solid #E0DDD5;">
                <svg width="64" height="64" fill="none" stroke="#D0CCC5" stroke-width="1.5" viewBox="0 0 24 24" style="margin-bottom: 1.5rem;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                </svg>
                <p style="font-size: 1.15rem; font-weight: 700; color: #1A1A1A; margin-bottom: 0.5rem;">Votre wishlist est vide</p>
                <p style="color: #767676; margin-bottom: 2rem;">Ajoutez des produits en cliquant sur le ❤ depuis n'importe quelle fiche produit.</p>
                <a href="{{ path('sylius_shop_homepage') }}" style="display: inline-block; background: #E87722; color: #fff; padding: 0.85rem 2rem; border-radius: 50px; font-weight: 700; text-decoration: none;">
                    Découvrir nos produits
                </a>
            </div>
        {% else %}
            {# Product grid #}
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem;">
                {% for item in items %}
                    {% set is_out_of_stock = (item.available_variants_count <= 0) %}
                    
                    <div style="background: #fff; border-radius: 12px; border: 1px solid #E0DDD5; overflow: hidden; display: flex; flex-direction: column; transition: transform 0.2s, box-shadow 0.2s; position: relative;"
                         onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 12px 24px rgba(0,0,0,0.06)'"
                         onmouseout="this.style.transform='';this.style.boxShadow=''">

                        {# Out of stock overlay badge #}
                        {% if is_out_of_stock %}
                            <div style="position: absolute; top: 12px; left: 12px; background: #d02020; color: #fff; padding: 0.25rem 0.6rem; border-radius: 6px; font-weight: 800; font-size: 0.7rem; text-transform: uppercase; z-index: 10; letter-spacing: 0.5px;">
                                Non disponible
                            </div>
                        {% endif %}

                        {# Product image #}
                        <a href="{{ path('sylius_shop_product_show', {'slug': item.product_slug, '_locale': sylius.localeCode}) }}"
                           style="display: flex; align-items: center; justify-content: center; background: #F5F0E8; height: 200px; overflow: hidden; padding: 0.5rem; opacity: {{ is_out_of_stock ? '0.6' : '1' }};">
                            {% if item.image_path %}
                                {% set img_src = item.image_path[0:4] == 'http' ? item.image_path : item.image_path|imagine_filter('sylius_shop_product_original') %}
                                <img src="{{ img_src }}" alt="{{ item.product_name }}"
                                     style="width: 100%; height: 100%; object-fit: contain; mix-blend-mode: multiply;">
                            {% else %}
                                <svg xmlns="http://www.w3.org/2000/svg" style="width:48px;height:48px;color:#d1d5db;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            {% endif %}
                        </a>

                        {# Content #}
                        <div style="padding: 1rem; display: flex; flex-direction: column; flex: 1;">
                            <a href="{{ path('sylius_shop_product_show', {'slug': item.product_slug, '_locale': sylius.localeCode}) }}"
                               style="font-weight: 700; color: #1A1A1A; text-decoration: none; font-size: 0.95rem; line-height: 1.3; margin-bottom: 0.5rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; opacity: {{ is_out_of_stock ? '0.6' : '1' }};">
                                {{ item.product_name }}
                            </a>

                            {% if item.price > 0 %}
                                <div style="font-size: 1.2rem; font-weight: 800; color: #E87722; margin-bottom: 1rem; opacity: {{ is_out_of_stock ? '0.6' : '1' }};">
                                    {{ (item.price / 100)|number_format(2, ',', ' ') }} €
                                </div>
                            {% endif %}

                            <div style="margin-top: auto; display: flex; gap: 0.5rem;">
                                {# Form to add to cart directly or redirect if complex #}
                                <form method="POST" action="{{ path('app_wishlist_add_to_cart', {id: item.product_id}) }}" style="flex: 1; margin: 0;">
                                     <button type="submit" 
                                             {% if is_out_of_stock %}disabled{% endif %}
                                             style="width: 100%; {% if is_out_of_stock %}background: #F5F4F0; color: #A09E99; cursor: not-allowed;{% else %}background: #E87722; color: #fff; cursor: pointer;{% endif %} border: none; border-radius: 8px; padding: 0.65rem; font-weight: 700; font-size: 0.85rem; text-align: center; display: flex; justify-content: center; align-items: center; gap: 0.5rem; transition: background 0.2s;" 
                                             {% if not is_out_of_stock %}onmouseover="this.style.background='#C85A00'" onmouseout="this.style.background='#E87722'"{% endif %}>
                                         <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
                                         <span class="d-none d-sm-inline">Ajouter</span>
                                     </button>
                                 </form>

                                <form method="POST" action="{{ path('app_wishlist_remove', {id: item.id}) }}" style="margin: 0;">
                                    <button type="submit" title="Retirer de la wishlist"
                                            style="background: #FFF0F0; border: 1px solid #FFC9C9; border-radius: 8px; width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: #dc2626; transition: background 0.2s;"
                                            onmouseover="this.style.background='#FFC9C9'" onmouseout="this.style.background='#FFF0F0'">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

    </div>
</div>
{% endblock %}
