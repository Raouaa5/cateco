{% extends '@SyliusShop/shared/layout/base.html.twig' %}

{% block title %}{{ 'sylius.shop.ui.search_results'|trans }} pour "{{ phrase }}" | {{ parent() }}{% endblock %}

{% block content %}
<div style="background: white; min-height: 80vh;">
    {# Hero-like Header for Search #}
    <div style="background: linear-gradient(135deg, #136a62 0%, #0d4a45 100%); padding: 4rem 2rem; text-align: center; color: white;">
        <div style="max-width: 1200px; margin: 0 auto;">
            <h1 style="font-family: 'Outfit', sans-serif; font-size: 3rem; font-weight: 800; margin-bottom: 1rem;">
                Résultats de recherche
            </h1>
            <p style="font-size: 1.25rem; opacity: 0.9;">
                {{ products|length }} produit(s) trouvé(s) pour <span style="font-weight: 700; color: #fbbf24;">"{{ phrase }}"</span>
            </p>
        </div>
    </div>

    <div style="max-width: 1400px; margin: 0 auto; padding: 4rem 2rem;">
        {% if products|length > 0 %}
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2.5rem;">
                {% for product in products %}
                    {% include '@SyliusShop/homepage/_product_card.html.twig' with {'product': product} %}
                {% endfor %}
            </div>
        {% else %}
            <div style="text-align: center; padding: 4rem 0;">
                <div style="background: #f3f4f6; width: 120px; height: 120px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 2rem;">
                    <svg style="width: 60px; height: 60px; color: #9ca3af;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <h2 style="font-size: 1.5rem; color: #374151; font-weight: 700; margin-bottom: 1rem;">Désolé, nous n'avons trouvé aucun résultat</h2>
                <p style="color: #6b7280; margin-bottom: 2rem;">Vérifiez l'orthographe ou essayez avec des mots-clés plus simples.</p>
                <a href="{{ path('sylius_shop_homepage') }}" style="display: inline-block; background: #f97316; color: white; padding: 1rem 2rem; border-radius: 30px; font-weight: 800; text-decoration: none; transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
                    Retour à l'accueil
                </a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
