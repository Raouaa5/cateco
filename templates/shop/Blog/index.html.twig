{% extends '@SyliusShop/shared/layout/base.html.twig' %}

{% block title %}Blog CATECO | Conseils & Astuces pour votre maison{% endblock %}

{% block content %}
<div style="background: white; min-height: 80vh; font-family: 'Outfit', sans-serif;">

    {# --- Hero Header --- #}
    <div style="background: linear-gradient(135deg, #40bdb8 0%, #2c8a86 100%); padding: 4rem 0 3rem; color: white; position: relative; overflow: hidden; border-radius: 0 0 3rem 3rem; margin-bottom: 3rem;">
        {# Photo on the right (Reflet en couleur avec masque fluide) #}
        <div style="position: absolute; top: 0; right: 0; height: 100%; width: 55%; z-index: 1; -webkit-mask-image: linear-gradient(to right, transparent 0%, black 35%); mask-image: linear-gradient(to right, transparent 0%, black 35%);">
            <img src="{{ asset('assets/shop/images/blog.png') }}" alt="" style="width: 100%; height: 100%; object-fit: cover; object-position: right 40%; display: block; opacity: 0.85;">
        </div>

        <div class="container mx-auto px-6 lg:px-12 relative" style="z-index: 2;">
            <nav style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; opacity: 0.9;">
                <a href="{{ path('sylius_shop_homepage') }}" style="color: white; text-decoration: none;">Accueil</a>
                <span style="opacity: 0.6;">/</span>
                <span style="font-weight: 600;">Blog</span>
            </nav>
            <h1 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; line-height: 1.1; margin: 0 0 1rem; letter-spacing: -0.02em;">
                Conseils &amp; Astuces
            </h1>
            <p style="font-size: 1.15rem; opacity: 0.9; max-width: 500px; margin: 0;">
                Découvrez nos articles pour mieux entretenir votre maison et votre jardin.
            </p>
        </div>
    </div>

    {# --- Blog Grid --- #}
    <div class="container mx-auto px-6 lg:px-12" style="padding-bottom: 5rem;">
        {% if posts is empty %}
            <div style="text-align: center; padding: 5rem 0; color: #6b7280;">
                <p style="font-size: 1.3rem;">Aucun article disponible pour le moment.</p>
            </div>
        {% else %}
            <div class="blog-grid">
                {% for post in posts %}
                    <article class="blog-card">
                        {# Image #}
                        <a href="{{ path('app_blog_post_show', {slug: post.slug}) }}" class="blog-card__image-link">
                            {% if post.image %}
                                <img src="{{ asset(post.image) }}"
                                     alt="{{ post.title }}"
                                     class="blog-card__image"
                                     onerror="this.src='{{ asset('assets/shop/images/blog/blog-default.jpg') }}'">
                            {% else %}
                                <div class="blog-card__image blog-card__image--placeholder">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" fill="none" viewBox="0 0 24 24" stroke="#ccc">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                </div>
                            {% endif %}
                        </a>

                        {# Card Body #}
                        <div class="blog-card__body">
                            <div class="blog-card__meta">
                                <span class="blog-card__date">{{ post.createdAt|date('d M Y') }}</span>
                            </div>
                            <h2 class="blog-card__title">
                                <a href="{{ path('app_blog_post_show', {slug: post.slug}) }}">{{ post.title }}</a>
                            </h2>
                            <p class="blog-card__excerpt">{{ post.excerpt }}</p>
                            <a href="{{ path('app_blog_post_show', {slug: post.slug}) }}" class="blog-card__btn">
                                EN SAVOIR PLUS
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="vertical-align: middle; margin-left: 6px;">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                </svg>
                            </a>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap');

    .blog-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }

    @media (max-width: 1024px) {
        .blog-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 640px) {
        .blog-grid { grid-template-columns: 1fr; }
    }

    .blog-card {
        background: #ffffff;
        border-radius: 1.25rem;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.07);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .blog-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 35px rgba(0, 0, 0, 0.12);
    }

    .blog-card__image-link {
        display: block;
        overflow: hidden;
        height: 220px;
        flex-shrink: 0;
    }

    .blog-card__image {
        width: 100%;
        height: 220px;
        object-fit: cover;
        display: block;
        transition: transform 0.4s ease;
    }

    .blog-card:hover .blog-card__image {
        transform: scale(1.05);
    }

    .blog-card__image--placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f3f4f6;
        height: 220px;
    }

    .blog-card__body {
        padding: 1.75rem;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .blog-card__meta {
        margin-bottom: 0.75rem;
    }

    .blog-card__date {
        font-size: 0.82rem;
        font-weight: 600;
        color: #40bdb8;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .blog-card__title {
        font-size: 1.15rem;
        font-weight: 700;
        color: #111827;
        line-height: 1.4;
        margin-bottom: 0.85rem;
        font-family: 'Outfit', sans-serif;
    }

    .blog-card__title a {
        color: inherit;
        text-decoration: none;
        transition: color 0.2s;
    }

    .blog-card__title a:hover {
        color: #40bdb8;
    }

    .blog-card__excerpt {
        font-size: 0.95rem;
        color: #6b7280;
        line-height: 1.7;
        flex: 1;
        margin-bottom: 1.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .blog-card__btn {
        display: inline-flex;
        align-items: center;
        font-size: 0.85rem;
        font-weight: 700;
        color: #2c8a86;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        border-bottom: 2px solid transparent;
        padding-bottom: 2px;
        transition: border-color 0.2s, color 0.2s;
        width: fit-content;
    }

    .blog-card__btn:hover {
        border-color: #2c8a86;
        color: #40bdb8;
    }
</style>
{% endblock %}
