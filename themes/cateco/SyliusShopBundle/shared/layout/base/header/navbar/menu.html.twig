{#
    Override: @SyliusShop/shared/layout/base/header/navbar/menu.html.twig
    This replaces the default Sylius category bar with the custom Cateco Mega-Menu.
#}

{% set categoryImages = {
    'anti-insectes': 'assets/shop/images/anti-insectes.jpg',
    'jardin': 'assets/shop/images/jardinage.jpg',
    'equipements-maison': 'assets/shop/images/meubles2.jpg',
    'plein-air': 'assets/shop/images/plein-air.jpg',
    'tentes-baches': 'assets/shop/images/tentes&baches.jpg',
    'nouveautes': 'assets/shop/images/Nouveautés.png',
    'bricolage-automobile': 'assets/shop/images/bricolage-roues.jpg',
    'sport-bien-etre': 'assets/shop/images/Sport-Bien-être.jpg',
    'noel': 'assets/shop/images/noel.jpg'
} %}

{# Map slugs to harmonious Cateco brand colors (Teals, Oranges, Greens) #}
{% set categoryColors = {
    'nouveautes': '#f97316',           
    'jardin': '#7ab835',               
    'equipements-maison': '#17716c',   
    'plein-air': '#ea580c',            
    'anti-insectes': '#4b5563',        
    'tentes-baches': '#40bdb8',        
    'bricolage-automobile': '#0f766e', 
    'sport-bien-etre': '#5ea138',      
    'noel': '#dc2626'                  
} %}

<style>
    /* Sticky Wrapper */
    .cateco-megamenu-wrapper {
        position: sticky;
        top: 72px; /* Offset to sit precisely beneath the 72px orange top bar */
        z-index: 9999;
        background-color: #ffffff;
        border-bottom: 3px solid #e5e7eb;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        font-family: inherit;
        width: 100%;
        margin-bottom: 0;
    }

    /* Wide unconstrained container to prevent Noel overflow */
    .cateco-nav-container {
        position: relative; /* Anchor for the absolute mega menu */
        width: 100%;
        max-width: 1600px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    /* Main Menu List - STRICTLY ONE LINE */
    .cateco-menu-list {
        display: flex;
        align-items: center;
        justify-content: space-evenly;
        list-style: none;
        margin: 0;
        padding: 0;
        gap: 0;
        flex-wrap: nowrap;
        min-width: max-content;
    }

    /* Top Level Item - Position static so the child panel anchors to the wrapper */
    .cateco-menu-item {
        position: static;
    }

    /* Top Level Link */
    .cateco-menu-link {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 1rem 0.6rem;
        color: #4b5563;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        text-decoration: none;
        letter-spacing: 0.02em;
        transition: all 0.2s;
        border-bottom: 1px solid transparent; /* Highlight line thinned */
        margin-bottom: 0;
        white-space: nowrap;
        border-radius: 8px 8px 0 0;
    }

    /* Hover State for Top Level - uses CSS variable injected on the <li> */
    .cateco-menu-item:hover .cateco-menu-link {
        background-color: var(--cat-color) !important;
        color: white !important;
    }
    .cateco-menu-item:hover .cateco-menu-link svg {
        color: white !important;
    }

    /* Mega Menu Dropdown Container - FULL WIDTH of site limits */
    .cateco-megamenu-panel {
        visibility: hidden;
        opacity: 0;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        width: 100%;
        background: #f8f9fa;
        border-radius: 0 0 12px 12px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        padding: 2rem;
        display: flex;
        justify-content: space-between;
        gap: 3rem;
        /* Delay hiding by 150ms so cursor can travel from tab to panel without it disappearing */
        transition: opacity 0.2s ease, visibility 0s ease 0.15s;
        pointer-events: none;
        z-index: 1000;
        cursor: default;
    }

    /* Show Dropdown on Hover - immediately with no delay */
    .cateco-menu-item:hover .cateco-megamenu-panel {
        visibility: visible;
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
        transition: opacity 0.2s ease, visibility 0s ease 0s;
    }

    /* Invisible hover bridge: covers the gap between the tab and the dropdown panel */
    .cateco-menu-item::after {
        content: '';
        position: absolute;
        bottom: -8px;
        left: 0;
        width: 100%;
        height: 8px;
        display: block;
    }

    /* Left Side: Subcategories — single vertical column (default: 3 or fewer) */
    .cateco-megamenu-links {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        align-content: start;
    }

    /* Two-column vertical layout for categories with more than 3 children */
    .cateco-megamenu-links.two-cols {
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-auto-flow: column;
        grid-template-rows: repeat(5, auto); /* max rows before wrapping to second col */
        gap: 0.75rem 3rem;
        align-content: start;
    }

    /* Subcategory Link */
    .cateco-sub-link {
        display: inline-flex;
        align-items: flex-start;
        gap: 0.75rem;
        color: #374151;
        font-weight: 700;
        font-size: 0.85rem;
        text-decoration: none;
        transition: color 0.2s;
        line-height: 1.3;
    }

    .cateco-sub-link:hover {
        color: #111827;
    }

    /* Green Square Bullet injected via JS/inline-style per category color */
    .cateco-sub-bullet {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 2px;
        flex-shrink: 0;
        margin-top: 5px; /* align with first line of multiline text */
    }

    /* Right Side: Featured Image Card */
    .cateco-megamenu-featured {
        width: 320px; /* Reduced width to prevent horizontal overflow */
        height: 180px;
        border-radius: 12px;
        overflow: hidden;
        position: relative;
        flex-shrink: 0;
        text-decoration: none;
        display: block;
    }

    .cateco-megamenu-featured img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .cateco-megamenu-featured:hover img {
        transform: scale(1.05);
    }

    /* Dark Overlay */
    .cateco-megamenu-featured-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.2) 100%);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 1.5rem;
        color: white;
    }

    .featured-title {
        font-size: 1.5rem;
        font-weight: 800;
        text-transform: uppercase;
        margin: 0 0 0.5rem 0;
        text-shadow: 0 2px 4px rgba(0,0,0,0.5);
        text-align: center;
    }

    .featured-cta {
        font-size: 0.85rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.25rem;
        border-bottom: 2px solid transparent;
        padding-bottom: 2px;
    }

    /* Chevron Icon */
    .chevron-down {
        width: 12px;
        height: 12px;
        transition: transform 0.3s;
    }
    .cateco-menu-item:hover .chevron-down {
        transform: rotate(180deg);
    }
</style>

<div class="cateco-megamenu-wrapper">
    <div class="cateco-nav-container">
        <ul class="cateco-menu-list">
            
            {% for taxon in taxons %}
                {# Filter out the specific category requested by user #}
                {% if 'produits-1-2-3' not in taxon.slug|lower %}
                    
                    {% set slugKey = taxon.slug|split('/')|last|lower %}
                    {% set catColor = categoryColors[slugKey] ?? '#17716c' %}
                    {% set imgSrc = categoryImages[slugKey] ?? 'assets/shop/images/jardinage.jpg' %}

                    <li class="cateco-menu-item" style="--cat-color: {{ catColor }};">
                        <a href="{{ path('sylius_shop_product_index', {'slug': taxon.slug, '_locale': sylius.localeCode}) }}" 
                           class="cateco-menu-link"
                           style="border-bottom-color: {{ catColor }};">
                            {{ taxon.name }}
                            
                            {% if taxon.enabledChildren|length > 0 %}
                                <svg class="chevron-down" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                                </svg>
                            {% endif %}
                        </a>

                        {# Mega Menu Panel - Only render if there are children #}
                        {% if taxon.enabledChildren|length > 0 %}
                            <div class="cateco-megamenu-panel" style="border-top-color: {{ catColor }};">
                                
                                {# Left: Subcategories List - 2 cols if > 3 children, else 1 col #}
                                {% set childCount = taxon.enabledChildren|length %}
                                <div class="cateco-megamenu-links{% if childCount > 3 %} two-cols{% endif %}" {% if childCount > 3 %}style="grid-template-rows: repeat({{ (childCount / 2)|round(0, 'ceil') }}, auto);"{% endif %}>
                                    {% for child in taxon.enabledChildren %}
                                        <a href="{{ path('sylius_shop_product_index', {'slug': child.slug, '_locale': sylius.localeCode}) }}" class="cateco-sub-link" onmouseover="this.style.color='{{ catColor }}'" onmouseout="this.style.color='#374151'">
                                            <span class="cateco-sub-bullet" style="background-color: {{ catColor }};"></span>
                                            <span>{{ child.name }}</span>
                                        </a>
                                    {% endfor %}
                                </div>

                                {# Right: Featured Image #}
                                <a href="{{ path('sylius_shop_product_index', {'slug': taxon.slug, '_locale': sylius.localeCode}) }}" class="cateco-megamenu-featured">
                                    
                                    {# Use Sylius image if exists, else fallback to mapped static image #}
                                    {% if taxon.images|length > 0 %}
                                        <img src="{{ asset('media/image/' ~ taxon.images.first.path) }}" alt="{{ taxon.name }}" onerror="this.onerror=null; this.src='{{ asset(imgSrc) }}'">
                                    {% else %}
                                        <img src="{{ asset(imgSrc) }}" alt="{{ taxon.name }}">
                                    {% endif %}

                                    <div class="cateco-megamenu-featured-overlay">
                                        <h3 class="featured-title">{{ taxon.name }}</h3>
                                        <div class="featured-cta" style="border-bottom-color: {{ catColor }};">
                                            Voir toute la catégorie
                                            <svg style="width:12px; height:12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/></svg>
                                        </div>
                                    </div>
                                </a>

                            </div>
                        {% endif %}
                    </li>

                {% endif %}
            {% endfor %}

        </ul>
    </div>
</div>
